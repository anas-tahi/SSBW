<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        .hero-section {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 3rem 0;
        }
        .product-card {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.15);
        }
        .product-price {
            font-size: 1.5rem;
            font-weight: bold;
            color: #667eea;
        }
        .search-section {
            background-color: #f8f9fa;
            padding: 2rem 0;
            margin-bottom: 2rem;
        }
        .navbar-brand {
            font-weight: bold;
            font-size: 1.5rem;
        }
        .footer {
            background-color: #343a40;
            color: white;
            padding: 2rem 0;
            margin-top: 3rem;
        }
        
        /* Modern Footer Styles */
        .modern-footer {
            position: relative;
            background: linear-gradient(135deg, #0a0a0f 0%, #1a1a2e 50%, #16213e 100%);
            color: #f0f0f0;
            margin-top: 80px;
            overflow: hidden;
        }
        
        .footer-bg {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at 20% 80%, rgba(201, 168, 76, 0.1) 0%, transparent 50%),
                        radial-gradient(circle at 80% 20%, rgba(120, 119, 198, 0.1) 0%, transparent 50%);
            z-index: 1;
        }
        
        .footer-container {
            position: relative;
            z-index: 2;
            max-width: 1200px;
            margin: 0 auto;
            padding: 60px 20px 30px;
        }
        
        .footer-top {
            display: grid;
            grid-template-columns: 1fr 2fr;
            gap: 60px;
            margin-bottom: 50px;
            padding-bottom: 40px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }
        
        .footer-brand {
            max-width: 350px;
        }
        
        .footer-logo {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 20px;
        }
        
        .footer-logo i {
            font-size: 2.5rem;
            background: linear-gradient(135deg, #c9a84c, #e8d070);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        
        .footer-title {
            font-size: 2rem;
            font-weight: 800;
            background: linear-gradient(135deg, #f0f0f0, #c9a84c);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        
        .footer-tagline {
            font-size: 1.1rem;
            color: #b8b8d1;
            margin-bottom: 25px;
            line-height: 1.6;
        }
        
        .footer-social {
            display: flex;
            gap: 15px;
        }
        
        .social-link {
            width: 45px;
            height: 45px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #b8b8d1;
            text-decoration: none;
            transition: all 0.3s ease;
            font-size: 1.2rem;
        }
        
        .social-link:hover {
            background: rgba(201, 168, 76, 0.1);
            border-color: #c9a84c;
            color: #c9a84c;
            transform: translateY(-3px);
        }
        
        .footer-links {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 40px;
        }
        
        .footer-heading {
            font-size: 1.2rem;
            font-weight: 700;
            color: #c9a84c;
            margin-bottom: 20px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .footer-list {
            list-style: none;
            padding: 0;
            margin: 0;
        }
        
        .footer-list li {
            margin-bottom: 12px;
        }
        
        .footer-link {
            color: #b8b8d1;
            text-decoration: none;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            font-size: 0.95rem;
        }
        
        .footer-link:hover {
            color: #c9a84c;
            transform: translateX(5px);
        }
        
        .footer-bottom {
            padding-top: 30px;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
        }
        
        .footer-bottom-content {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 30px;
        }
        
        .footer-copyright p {
            margin: 0 0 8px 0;
            color: #b8b8d1;
            font-size: 0.9rem;
        }
        
        .footer-made {
            color: #666;
            font-size: 0.85rem;
        }
        
        .footer-payment {
            text-align: right;
        }
        
        .payment-title {
            display: block;
            color: #b8b8d1;
            font-size: 0.9rem;
            margin-bottom: 10px;
        }
        
        .payment-icons {
            display: flex;
            gap: 15px;
            font-size: 1.3rem;
            color: #b8b8d1;
        }
        
        .payment-icons i {
            transition: all 0.3s ease;
        }
        
        .payment-icons i:hover {
            color: #c9a84c;
            transform: translateY(-2px);
        }
        
        /* Footer Animations */
        .modern-footer {
            animation: footerFadeIn 1s ease-out;
        }
        
        @keyframes footerFadeIn {
            from {
                opacity: 0;
                transform: translateY(50px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        .footer-logo {
            animation: logoGlow 3s ease-in-out infinite alternate;
        }
        
        @keyframes logoGlow {
            from {
                filter: brightness(1);
            }
            to {
                filter: brightness(1.2);
            }
        }
        
        .footer-bg::before {
            content: '';
            position: absolute;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(201, 168, 76, 0.05) 0%, transparent 70%);
            top: -300px;
            left: -200px;
            border-radius: 50%;
            filter: blur(100px);
            animation: floatFooter 20s ease-in-out infinite alternate;
        }
        
        .footer-bg::after {
            content: '';
            position: absolute;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(120, 119, 198, 0.05) 0%, transparent 70%);
            bottom: -200px;
            right: -150px;
            border-radius: 50%;
            filter: blur(80px);
            animation: floatFooter 25s ease-in-out infinite alternate-reverse;
        }
        
        @keyframes floatFooter {
            0% { transform: translate(0, 0) scale(1); }
            50% { transform: translate(30px, 40px) scale(1.1); }
            100% { transform: translate(15px, 20px) scale(1); }
        }
        
        /* Responsive Footer */
        @media (max-width: 768px) {
            .footer-top {
                grid-template-columns: 1fr;
                gap: 40px;
                text-align: center;
            }
            
            .footer-links {
                grid-template-columns: 1fr;
                gap: 30px;
                text-align: center;
            }
            
            .footer-bottom-content {
                flex-direction: column;
                text-align: center;
                gap: 20px;
            }
            
            .footer-payment {
                text-align: center;
            }
            
            .footer-container {
                padding: 40px 15px 20px;
            }
        }
    </style>
    {% block head %}{% endblock %}
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">🎨 Tienda Prado</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/">Inicio</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/buscar">Buscar</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/contacto">Contacto</a>
                    </li>
                </ul>

                <ul class="navbar-nav">
                    <!-- Cart Section - Only show if logged in -->
                    {% if usuario %}
                    <li class="nav-item">
                        <a class="nav-link position-relative" href="/carrito">
                            <i class="bi bi-cart3"></i>
                            Cart
                            {% if total_carrito > 0 %}
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                    {{ total_carrito }}
                                    <span class="visually-hidden">items in cart</span>
                                </span>
                            {% endif %}
                        </a>
                    </li>
                    {% endif %}

                    {% if usuario %}
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle me-1"></i>
                                {{ usuario }}
                                {% if admin %}
                                    <i class="bi bi-shield-check ms-1 text-warning"></i>
                                {% endif %}
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><h6 class="dropdown-header">
                                    <i class="bi bi-person me-2"></i>{{ email }}
                                </h6></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="/profile">
                                    <i class="bi bi-person me-2"></i>Mi Perfil
                                </a></li>
                                {% if admin %}
                                    <li><a class="dropdown-item" href="/admin">
                                        <i class="bi bi-gear me-2"></i>Panel Admin
                                    </a></li>
                                {% endif %}
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="/logout">
                                    <i class="bi bi-box-arrow-right me-2"></i>Cerrar Sesión
                                </a></li>
                            </ul>
                        </li>
                    {% else %}
                        <li class="nav-item">
                            <a class="nav-link" href="/login">
                                <i class="bi bi-box-arrow-in-right me-1"></i>Iniciar Sesión
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/register">
                                <i class="bi bi-person-plus me-1"></i>Registrarse
                            </a>
                        </li>
                    {% endif %}
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main>
        {% block content %}{% endblock %}
    </main>

    <!-- Modern Footer -->
    <footer class="modern-footer">
        <!-- Animated Background -->
        <div class="footer-bg"></div>
        
        <!-- Footer Content -->
        <div class="footer-container">
            <!-- Top Section -->
            <div class="footer-top">
                <div class="footer-brand">
                    <div class="footer-logo">
                        <i class="bi bi-palette-fill"></i>
                        <span class="footer-title">Tienda Prado</span>
                    </div>
                    <p class="footer-tagline">Galería de Arte Impreso de Alta Calidad</p>
                    <div class="footer-social">
                        <a href="#" class="social-link">
                            <i class="bi bi-facebook"></i>
                        </a>
                        <a href="#" class="social-link">
                            <i class="bi bi-instagram"></i>
                        </a>
                        <a href="#" class="social-link">
                            <i class="bi bi-twitter"></i>
                        </a>
                        <a href="#" class="social-link">
                            <i class="bi bi-pinterest"></i>
                        </a>
                    </div>
                </div>
                
                <div class="footer-links">
                    <div class="footer-column">
                        <h4 class="footer-heading">Tienda</h4>
                        <ul class="footer-list">
                            <li><a href="/" class="footer-link">Inicio</a></li>
                            <li><a href="/buscar" class="footer-link">Buscar</a></li>
                            <li><a href="/contacto" class="footer-link">Contacto</a></li>
                            <li><a href="/acerca" class="footer-link">Acerca de</a></li>
                        </ul>
                    </div>
                    
                    <div class="footer-column">
                        <h4 class="footer-heading">Ayuda</h4>
                        <ul class="footer-list">
                            <li><a href="#" class="footer-link">FAQ</a></li>
                            <li><a href="#" class="footer-link">Envíos</a></li>
                            <li><a href="#" class="footer-link">Devoluciones</a></li>
                            <li><a href="#" class="footer-link">Términos</a></li>
                        </ul>
                    </div>
                    
                    <div class="footer-column">
                        <h4 class="footer-heading">Contacto</h4>
                        <ul class="footer-list">
                            <li><a href="mailto:info@tiendaprado.com" class="footer-link">info@tiendaprado.com</a></li>
                            <li><a href="tel:+34912345678" class="footer-link">+34 912 345 678</a></li>
                            <li><a href="#" class="footer-link">Madrid, España</a></li>
                            <li><a href="#" class="footer-link">Lun-Sáb: 10:00-20:00</a></li>
                        </ul>
                    </div>
                </div>
            </div>
            
            <!-- Bottom Section -->
            <div class="footer-bottom">
                <div class="footer-bottom-content">
                    <div class="footer-copyright">
                        <p>&copy; 2026 Tienda Prado → Impresiones. Todos los derechos reservados.</p>
                        <p class="footer-made">Hecho con <i class="bi bi-heart-fill text-danger"></i> para amantes del arte</p>
                    </div>
                    
                    <div class="footer-payment">
                        <span class="payment-title">Métodos de pago:</span>
                        <div class="payment-icons">
                            <i class="bi bi-credit-card-fill"></i>
                            <i class="bi bi-paypal"></i>
                            <i class="bi bi-apple"></i>
                            <i class="bi bi-google"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
