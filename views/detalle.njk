{% extends "base.njk" %}

{% block head %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
body { 
    background: #0a0a0f !important; 
    color: #f0f0f0; 
    font-family: 'Outfit', sans-serif;
    overflow-x: hidden;
}

/* Animated Background */
.detalle-bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #0a0a0f 0%, #1a1a2e 50%, #16213e 100%);
    z-index: -2;
}

.detalle-bg::before {
    content: '';
    position: absolute;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(120, 119, 198, 0.3) 0%, transparent 70%);
    top: -200px;
    left: -150px;
    border-radius: 50%;
    filter: blur(80px);
    animation: floatBlob 20s ease-in-out infinite alternate;
}

.detalle-bg::after {
    content: '';
    position: absolute;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(198, 120, 221, 0.3) 0%, transparent 70%);
    bottom: -100px;
    right: -100px;
    border-radius: 50%;
    filter: blur(80px);
    animation: floatBlob 25s ease-in-out infinite alternate-reverse;
}

@keyframes floatBlob {
    0% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(60px, 80px) scale(1.1); }
    100% { transform: translate(30px, 40px) scale(1); }
}

/* Main Container */
.detalle-container {
    min-height: 100vh;
    padding: 40px 20px 80px;
    position: relative;
    z-index: 1;
}

/* Breadcrumb */
.detalle-breadcrumb {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 50px;
    padding: 15px 30px;
    margin-bottom: 40px;
    animation: slideDown 0.8s ease-out;
}

.detalle-breadcrumb .breadcrumb {
    margin: 0;
    background: none;
}

.detalle-breadcrumb .breadcrumb-item a {
    color: #b8b8d1;
    text-decoration: none;
    transition: all 0.3s ease;
    font-weight: 500;
}

.detalle-breadcrumb .breadcrumb-item a:hover {
    color: #c9a84c;
    transform: translateX(3px);
}

.detalle-breadcrumb .breadcrumb-item.active {
    color: #f0f0f0;
    font-weight: 600;
}

/* Product Grid */
.detalle-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    max-width: 1400px;
    margin: 0 auto;
    align-items: start;
}

/* Image Section */
.detalle-image-section {
    animation: slideInLeft 1s ease-out;
}

.image-main-container {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.3);
    transition: all 0.5s ease;
}

.image-main-container:hover {
    transform: translateY(-10px);
    box-shadow: 0 35px 70px rgba(120, 119, 198, 0.3);
}

.image-main {
    width: 100%;
    height: 600px;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
}

.image-main-container:hover .image-main {
    transform: scale(1.05);
}

.image-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.3) 100%);
    opacity: 0;
    transition: opacity 0.3s ease;
}

.image-main-container:hover .image-overlay {
    opacity: 1;
}

.image-zoom-hint {
    position: absolute;
    top: 20px;
    right: 20px;
    background: rgba(0, 0, 0, 0.7);
    color: white;
    padding: 8px 12px;
    border-radius: 20px;
    font-size: 0.8rem;
    opacity: 0;
    transition: opacity 0.3s ease;
}

.image-main-container:hover .image-zoom-hint {
    opacity: 1;
}

/* Image Gallery */
.image-gallery {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 15px;
    margin-top: 20px;
}

.gallery-thumb {
    aspect-ratio: 1;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    overflow: hidden;
    cursor: pointer;
    transition: all 0.3s ease;
    position: relative;
}

.gallery-thumb:hover {
    transform: scale(1.05);
    border-color: #c9a84c;
    box-shadow: 0 10px 25px rgba(201, 168, 76, 0.3);
}

.gallery-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
}

.gallery-thumb:hover img {
    transform: scale(1.1);
}

/* Info Section */
.detalle-info-section {
    animation: slideInRight 1s ease-out;
}

.product-badge {
    display: inline-block;
    background: linear-gradient(135deg, #c9a84c, #e8d070);
    color: #0a0a0f;
    padding: 6px 16px;
    border-radius: 25px;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 20px;
    animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.05); }
}

.product-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 30px;
    background: linear-gradient(135deg, #f0f0f0, #c9a84c);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: titleGlow 3s ease-in-out infinite alternate;
}

@keyframes titleGlow {
    0% { filter: brightness(1); }
    100% { filter: brightness(1.2); }
}

.price-container {
    display: flex;
    align-items: baseline;
    gap: 15px;
    margin-bottom: 40px;
}

.product-price {
    font-size: 3rem;
    font-weight: 700;
    color: #c9a84c;
    font-family: 'Space Mono', monospace;
    text-shadow: 0 0 20px rgba(201, 168, 76, 0.5);
}

.price-original {
    font-size: 1.5rem;
    color: #666;
    text-decoration: line-through;
}

.price-savings {
    background: rgba(76, 175, 80, 0.2);
    color: #4caf50;
    padding: 4px 12px;
    border-radius: 15px;
    font-size: 0.9rem;
    font-weight: 600;
}

/* Description */
.description-section {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    padding: 30px;
    margin-bottom: 40px;
    backdrop-filter: blur(10px);
}

.section-title {
    font-size: 1.3rem;
    font-weight: 600;
    color: #c9a84c;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
}

.section-title::before {
    content: '';
    width: 4px;
    height: 20px;
    background: linear-gradient(135deg, #c9a84c, #e8d070);
    border-radius: 2px;
}

.description-text {
    color: #b8b8d1;
    line-height: 1.8;
    font-size: 1.1rem;
}

/* Features */
.features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-bottom: 40px;
}

.feature-item {
    display: flex;
    align-items: center;
    gap: 15px;
    padding: 20px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 15px;
    transition: all 0.3s ease;
}

.feature-item:hover {
    transform: translateY(-3px);
    border-color: #c9a84c;
    box-shadow: 0 10px 25px rgba(201, 168, 76, 0.2);
}

.feature-icon {
    width: 50px;
    height: 50px;
    background: linear-gradient(135deg, #c9a84c, #e8d070);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #0a0a0f;
    font-size: 1.2rem;
    flex-shrink: 0;
}

.feature-text {
    color: #b8b8d1;
    font-weight: 500;
}

/* Specifications */
.specs-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    margin-bottom: 40px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 15px;
    overflow: hidden;
}

.specs-table td {
    padding: 15px 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

.specs-table tr:last-child td {
    border-bottom: none;
}

.specs-table tr:nth-child(even) {
    background: rgba(255, 255, 255, 0.02);
}

.spec-label {
    font-weight: 600;
    color: #c9a84c;
    width: 40%;
}

.spec-value {
    color: #b8b8d1;
}

/* Action Section */
.action-section {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 40px;
}

.quantity-selector {
    display: flex;
    align-items: center;
    gap: 15px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 15px;
    padding: 20px;
}

.quantity-label {
    font-weight: 600;
    color: #b8b8d1;
}

.quantity-input {
    width: 80px;
    padding: 10px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 10px;
    color: #f0f0f0;
    text-align: center;
    font-size: 1.1rem;
}

.quantity-input:focus {
    outline: none;
    border-color: #c9a84c;
    box-shadow: 0 0 0 3px rgba(201, 168, 76, 0.1);
}

.action-buttons {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 15px;
}

.add-to-cart-btn {
    background: linear-gradient(135deg, #c9a84c, #e8d070);
    color: #0a0a0f;
    border: none;
    border-radius: 15px;
    padding: 18px 30px;
    font-size: 1.1rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    position: relative;
    overflow: hidden;
}

.add-to-cart-btn::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
    transition: left 0.5s ease;
}

.add-to-cart-btn:hover::before {
    left: 100%;
}

.add-to-cart-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 35px rgba(201, 168, 76, 0.4);
}

.wishlist-btn {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 15px;
    padding: 18px;
    color: #b8b8d1;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
}

.wishlist-btn:hover {
    background: rgba(201, 168, 76, 0.1);
    border-color: #c9a84c;
    color: #c9a84c;
    transform: translateY(-3px);
}

/* Share Section */
.share-section {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 15px;
    padding: 25px;
}

.share-buttons {
    display: flex;
    gap: 10px;
    margin-top: 15px;
}

.share-btn {
    width: 45px;
    height: 45px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.05);
    color: #b8b8d1;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
}

.share-btn:hover {
    transform: translateY(-3px) scale(1.1);
}

.share-btn.facebook:hover {
    background: #1877f2;
    border-color: #1877f2;
    color: white;
}

.share-btn.twitter:hover {
    background: #1da1f2;
    border-color: #1da1f2;
    color: white;
}

.share-btn.whatsapp:hover {
    background: #25d366;
    border-color: #25d366;
    color: white;
}

.share-btn.link:hover {
    background: #c9a84c;
    border-color: #c9a84c;
    color: #0a0a0f;
}

/* Related Products */
.related-section {
    margin-top: 100px;
    padding-top: 60px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
}

.related-header {
    text-align: center;
    margin-bottom: 50px;
}

.related-title {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 15px;
    background: linear-gradient(135deg, #f0f0f0, #c9a84c);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.related-subtitle {
    color: #b8b8d1;
    font-size: 1.1rem;
}

.related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
}

.related-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    overflow: hidden;
    transition: all 0.3s ease;
    cursor: pointer;
}

.related-card:hover {
    transform: translateY(-10px);
    border-color: #c9a84c;
    box-shadow: 0 20px 40px rgba(201, 168, 76, 0.3);
}

.related-image {
    width: 100%;
    height: 200px;
    object-fit: cover;
}

.related-info {
    padding: 25px;
}

.related-title {
    font-size: 1.2rem;
    font-weight: 600;
    color: #f0f0f0;
    margin-bottom: 10px;
}

.related-price {
    font-size: 1.5rem;
    font-weight: 700;
    color: #c9a84c;
    font-family: 'Space Mono', monospace;
}

/* Animations */
@keyframes slideDown {
    from {
        opacity: 0;
        transform: translateY(-30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes slideInLeft {
    from {
        opacity: 0;
        transform: translateX(-50px);
    }
    to {
        opacity: 1;
        transform: translateX(0);
    }
}

@keyframes slideInRight {
    from {
        opacity: 0;
        transform: translateX(50px);
    }
    to {
        opacity: 1;
        transform: translateX(0);
    }
}

/* Responsive Design */
@media (max-width: 1024px) {
    .detalle-grid {
        grid-template-columns: 1fr;
        gap: 60px;
    }
    
    .image-main {
        height: 500px;
    }
}

@media (max-width: 768px) {
    .detalle-container {
        padding: 20px 15px 60px;
    }
    
    .detalle-breadcrumb {
        padding: 12px 20px;
        margin-bottom: 30px;
    }
    
    .product-title {
        font-size: 2rem;
    }
    
    .product-price {
        font-size: 2.5rem;
    }
    
    .features-grid {
        grid-template-columns: 1fr;
    }
    
    .action-buttons {
        grid-template-columns: 1fr;
    }
    
    .image-gallery {
        grid-template-columns: repeat(2, 1fr);
    }
    
    .related-grid {
        grid-template-columns: 1fr;
    }
}

@media (max-width: 480px) {
    .image-main {
        height: 300px;
    }
    
    .product-title {
        font-size: 1.5rem;
    }
    
    .product-price {
        font-size: 2rem;
    }
    
    .quantity-selector {
        flex-direction: column;
        align-items: stretch;
        gap: 10px;
    }
    
    .share-buttons {
        justify-content: center;
    }
}
</style>
{% endblock %}

{% block content %}
<div class="detalle-bg"></div>

<div class="detalle-container">
    <!-- Breadcrumb -->
    <nav class="detalle-breadcrumb">
        <div class="container">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item">
                    <a href="/" class="text-decoration-none">
                        <i class="bi bi-house me-2"></i>Inicio
                    </a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">{{ producto.título }}</li>
            </ol>
        </div>
    </nav>

    <!-- Product Grid -->
    <div class="container">
        <div class="detalle-grid">
            <!-- Image Section -->
            <div class="detalle-image-section">
                <div class="image-main-container">
                    {% if producto.imagen %}
                        <img src="/imagenes/{{ producto.imagen }}" 
                             alt="{{ producto.título }}" 
                             class="image-main">
                    {% else %}
                        <div class="image-main d-flex align-items-center justify-content-center">
                            <div class="text-center">
                                <i class="bi bi-image display-1 text-muted mb-3"></i>
                                <p class="text-muted">Imagen no disponible</p>
                            </div>
                        </div>
                    {% endif %}
                    <div class="image-overlay"></div>
                    <div class="image-zoom-hint">
                        <i class="bi bi-zoom-in me-2"></i>Hover para ampliar
                    </div>
                </div>
                
                <!-- Image Gallery -->
                <div class="image-gallery">
                    <div class="gallery-thumb">
                        {% if producto.imagen %}
                            <img src="/imagenes/{{ producto.imagen }}" alt="Vista 1">
                        {% else %}
                            <div class="d-flex align-items-center justify-content-center h-100">
                                <i class="bi bi-image text-muted"></i>
                            </div>
                        {% endif %}
                    </div>
                    <div class="gallery-thumb">
                        <div class="d-flex align-items-center justify-content-center h-100">
                            <i class="bi bi-image text-muted"></i>
                        </div>
                    </div>
                    <div class="gallery-thumb">
                        <div class="d-flex align-items-center justify-content-center h-100">
                            <i class="bi bi-image text-muted"></i>
                        </div>
                    </div>
                    <div class="gallery-thumb">
                        <div class="d-flex align-items-center justify-content-center h-100">
                            <i class="bi bi-image text-muted"></i>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Info Section -->
            <div class="detalle-info-section">
                <!-- Badge -->
                <div class="product-badge">
                    <i class="bi bi-star-fill me-2"></i>Edición Limitada
                </div>
                
                <!-- Title -->
                <h1 class="product-title">{{ producto.título }}</h1>
                
                <!-- Price -->
                <div class="price-container">
                    <span class="product-price">€{{ producto.precio }}</span>
                    <span class="price-original">€{{ (producto.precio * 1.3)|round(2) }}</span>
                    <span class="price-savings">Ahorra 30%</span>
                </div>
                
                <!-- Description -->
                <div class="description-section">
                    <h3 class="section-title">
                        <i class="bi bi-file-text me-2"></i>Descripción
                    </h3>
                    <p class="description-text">{{ producto.descripción }}</p>
                </div>
                
                <!-- Features -->
                <div class="features-grid">
                    <div class="feature-item">
                        <div class="feature-icon">
                            <i class="bi bi-award"></i>
                        </div>
                        <span class="feature-text">Impresión de alta calidad</span>
                    </div>
                    <div class="feature-item">
                        <div class="feature-icon">
                            <i class="bi bi-palette"></i>
                        </div>
                        <span class="feature-text">Papel premium de 200g/m²</span>
                    </div>
                    <div class="feature-item">
                        <div class="feature-icon">
                            <i class="bi bi-droplet"></i>
                        </div>
                        <span class="feature-text">Colores vibrantes y duraderos</span>
                    </div>
                    <div class="feature-item">
                        <div class="feature-icon">
                            <i class="bi bi-shield-check"></i>
                        </div>
                        <span class="feature-text">Certificado de autenticidad</span>
                    </div>
                </div>
                
                <!-- Specifications -->
                <div class="description-section">
                    <h3 class="section-title">
                        <i class="bi bi-info-circle me-2"></i>Especificaciones
                    </h3>
                    <table class="specs-table">
                        <tr>
                            <td class="spec-label">ID Producto</td>
                            <td class="spec-value">#{{ producto.id }}</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Tamaño</td>
                            <td class="spec-value">Personalizable</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Material</td>
                            <td class="spec-value">Papel fotográfico premium</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Acabado</td>
                            <td class="spec-value">Brillante o mate</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Entrega</td>
                            <td class="spec-value">3-5 días laborables</td>
                        </tr>
                    </table>
                </div>
                
                <!-- Action Section -->
                <div class="action-section">
                    <div class="quantity-selector">
                        <span class="quantity-label">Cantidad:</span>
                        <input type="number" 
                               class="quantity-input" 
                               value="1" 
                               min="1" 
                               max="10"
                               id="quantityInput">
                    </div>
                    
                    {% if usuario %}
                        <form action="/al-carrito/{{ producto.id }}" method="POST" class="action-buttons">
                            <input type="hidden" name="cantidad" id="hiddenQuantity" value="1">
                            <button type="submit" class="add-to-cart-btn">
                                <i class="bi bi-cart-plus"></i>
                                <span>Añadir a la cesta</span>
                            </button>
                        </form>
                    {% else %}
                        <button type="button" class="add-to-cart-btn" onclick="showLoginPrompt()" style="cursor: not-allowed; opacity: 0.7;">
                            <i class="bi bi-lock"></i>
                            <span>Inicia sesión para comprar</span>
                        </button>
                    {% endif %}
                    
                    <button class="wishlist-btn">
                        <i class="bi bi-heart"></i>
                    </button>
                </div>
                
                <!-- Share Section -->
                <div class="share-section">
                    <h3 class="section-title">
