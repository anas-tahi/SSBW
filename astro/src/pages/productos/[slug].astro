---
import Layout from '../../layouts/Layout.astro';
import productosData from '../../../data/productos.json';

export async function getStaticPaths() {
  return productosData.map((pr, index) => ({
    params: { slug: String(index) },
    props: { producto: pr }
  }));
}

const { producto } = Astro.props;
const titulo = producto.título;
const descripcion = producto.descripción;
---
<Layout title={`${titulo} — Tienda Prado`}>
  <div style="min-height:100vh; background:#f9fafb; padding:3rem 1rem;">
    <div style="max-width:900px; margin:0 auto;">
      <a href="/ssg" style="color:#c0392b; text-decoration:none; display:inline-block; margin-bottom:2rem;">
        &larr; Volver a Destacados
      </a>
      <div style="background:white; border-radius:1rem; box-shadow:0 4px 20px rgba(0,0,0,0.1); overflow:hidden; display:grid; grid-template-columns:1fr 1fr;">
        <div style="background:#f3f4f6; display:flex; align-items:center; justify-content:center; padding:2rem;">
          <img src={`/images/${producto.imagen}`} alt={titulo}
            style="max-height:320px; object-fit:contain; border-radius:0.5rem;"
            onerror="this.src='https://via.placeholder.com/400x400?text=Tienda+Prado'" />
        </div>
        <div style="padding:2rem; display:flex; flex-direction:column; justify-content:center;">
          <h1 style="font-size:1.75rem; color:#1a1a1a; margin-bottom:1rem;">{titulo}</h1>
          <p style="color:#4b5563; margin-bottom:1.5rem; line-height:1.6;">{descripcion}</p>
          <p style="font-size:1.5rem; font-weight:700; color:#c0392b; margin-bottom:1.5rem;">
            {producto.texto_precio}
          </p>
        </div>
      </div>
    </div>
  </div>
</Layout>
