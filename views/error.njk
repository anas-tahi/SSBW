{% extends "base.njk" %}

{% block content %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card border-0 shadow">
                <div class="card-body p-5">
                    <i class="bi bi-exclamation-triangle display-1 text-warning mb-4"></i>
                    <h1 class="display-4 fw-bold mb-3">{{ title }}</h1>
                    <p class="lead text-muted mb-4">{{ message }}</p>
                    
                    <div class="d-grid gap-2 d-md-flex justify-content-md-center">
                        <a href="/" class="btn btn-primary">
                            <i class="bi bi-house"></i> Volver al inicio
                        </a>
                        <a href="/buscar" class="btn btn-outline-secondary">
                            <i class="bi bi-search"></i> Buscar productos
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
