{% extends "base.njk" %}

{% block head %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
body { 
    background: #0a0a0f !important; 
    color: #f0f0f0; 
    font-family: 'Outfit', sans-serif;
    overflow-x: hidden;
}

/* Animated Background */
.auth-bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #0a0a0f 0%, #1a1a2e 50%, #16213e 100%);
    z-index: -2;
}

.auth-bg::before {
    content: '';
    position: absolute;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(201, 168, 76, 0.15) 0%, transparent 70%);
    top: -200px;
    left: -150px;
    border-radius: 50%;
    filter: blur(100px);
    animation: floatBlob 20s ease-in-out infinite alternate;
}

.auth-bg::after {
    content: '';
    position: absolute;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(120, 119, 198, 0.15) 0%, transparent 70%);
    bottom: -100px;
    right: -100px;
    border-radius: 50%;
    filter: blur(80px);
    animation: floatBlob 25s ease-in-out infinite alternate-reverse;
}

@keyframes floatBlob {
    0% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(60px, 80px) scale(1.1); }
    100% { transform: translate(30px, 40px) scale(1); }
}

/* Main Container */
.auth-container {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
    position: relative;
    z-index: 1;
}

/* Auth Card */
.auth-card {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 30px;
    padding: 60px 50px;
    max-width: 500px;
    width: 100%;
    animation: slideUp 0.8s ease-out;
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.3);
}

@keyframes slideUp {
    from {
        opacity: 0;
        transform: translateY(50px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* Header Section */
.auth-header {
    text-align: center;
    margin-bottom: 50px;
}

.auth-icon {
    width: 100px;
    height: 100px;
    background: linear-gradient(135deg, #c9a84c, #e8d070);
    border-radius: 25px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 30px;
    font-size: 3rem;
    color: #0a0a0f;
    animation: iconGlow 3s ease-in-out infinite alternate;
    box-shadow: 0 15px 35px rgba(201, 168, 76, 0.3);
}

@keyframes iconGlow {
    0% { transform: scale(1); box-shadow: 0 15px 35px rgba(201, 168, 76, 0.3); }
    100% { transform: scale(1.05); box-shadow: 0 20px 45px rgba(201, 168, 76, 0.5); }
}

.auth-title {
    font-size: 2.5rem;
    font-weight: 800;
    background: linear-gradient(135deg, #f0f0f0, #c9a84c);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 15px;
}

.auth-subtitle {
    color: #b8b8d1;
    font-size: 1.1rem;
    font-weight: 300;
}

/* Form Styles */
.auth-form {
    margin-bottom: 40px;
}

.form-group {
    margin-bottom: 25px;
}

.form-label {
    display: block;
    color: #c9a84c;
    font-weight: 600;
    margin-bottom: 10px;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.form-input {
    width: 100%;
    padding: 18px 20px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 15px;
    color: #f0f0f0;
    font-size: 1rem;
    transition: all 0.3s ease;
    font-family: 'Outfit', sans-serif;
}

.form-input::placeholder {
    color: rgba(255, 255, 255, 0.3);
}

.form-input:focus {
    outline: none;
    border-color: #c9a84c;
    background: rgba(255, 255, 255, 0.08);
    box-shadow: 0 0 20px rgba(201, 168, 76, 0.3);
    transform: translateY(-2px);
}

/* Submit Button */
.auth-submit-btn {
    width: 100%;
    padding: 20px;
    background: linear-gradient(135deg, #c9a84c, #e8d070);
    color: #0a0a0f;
    border: none;
    border-radius: 15px;
    font-size: 1.1rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
    margin-top: 30px;
}

.auth-submit-btn::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
    transition: left 0.5s ease;
}

.auth-submit-btn:hover::before {
    left: 100%;
}

.auth-submit-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 20px 40px rgba(201, 168, 76, 0.4);
}

/* Alert Messages */
.alert-message {
    padding: 18px 25px;
    border-radius: 15px;
    margin-bottom: 30px;
    display: flex;
    align-items: center;
    gap: 15px;
    animation: alertSlide 0.5s ease-out;
}

@keyframes alertSlide {
    from {
        opacity: 0;
        transform: translateY(-20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.alert-success {
    background: rgba(76, 175, 80, 0.1);
    border: 1px solid rgba(76, 175, 80, 0.3);
    color: #4CAF50;
}

.alert-error {
    background: rgba(244, 67, 54, 0.1);
    border: 1px solid rgba(244, 67, 54, 0.3);
    color: #f44336;
}

.alert-icon {
    font-size: 1.5rem;
}

.alert-content h4 {
    margin: 0 0 5px 0;
    font-weight: 700;
}

.alert-content p {
    margin: 0;
    font-size: 0.9rem;
}

/* Divider */
.auth-divider {
    text-align: center;
    margin: 40px 0;
    position: relative;
}

.auth-divider::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 1px;
    background: rgba(255, 255, 255, 0.1);
}

.auth-divider span {
    background: rgba(10, 10, 15, 0.8);
    padding: 0 20px;
    color: #b8b8d1;
    font-size: 0.9rem;
}

/* Switch Auth */
.switch-auth {
    text-align: center;
    margin-top: 30px;
}

.switch-auth p {
    color: #b8b8d1;
    margin-bottom: 15px;
}

.switch-auth a {
    color: #c9a84c;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
}

.switch-auth a:hover {
    color: #e8d070;
    text-shadow: 0 0 10px rgba(201, 168, 76, 0.5);
}

/* Test Account Section */
.test-account {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 20px;
    padding: 25px;
    margin-top: 30px;
    text-align: center;
}

.test-title {
    color: #c9a84c;
    font-weight: 700;
    margin-bottom: 15px;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.test-info {
    color: #b8b8d1;
    font-size: 0.9rem;
    line-height: 1.6;
}

.test-credentials {
    background: rgba(0, 0, 0, 0.3);
    border-radius: 10px;
    padding: 15px;
    margin-top: 15px;
    font-family: 'Space Mono', monospace;
    font-size: 0.85rem;
    color: #e8d070;
}

/* Responsive Design */
@media (max-width: 768px) {
    .auth-card {
        padding: 40px 30px;
        margin: 20px;
    }
    
    .auth-title {
        font-size: 2rem;
    }
    
    .auth-icon {
        width: 80px;
        height: 80px;
        font-size: 2.5rem;
    }
}
</style>
{% endblock %}

{% block content %}
<div class="auth-bg"></div>

<div class="auth-container">
    <div class="auth-card">
        <!-- Header -->
        <div class="auth-header">
            <div class="auth-icon">
                <i class="bi bi-shield-lock-fill"></i>
            </div>
            <h1 class="auth-title">Iniciar Sesión</h1>
            <p class="auth-subtitle">Accede a tu cuenta de Tienda Prado</p>
        </div>

        <!-- Alert Messages -->
        {% if error %}
            <div class="alert-message alert-error">
                <div class="alert-icon">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                </div>
                <div class="alert-content">
                    <h4>Error de autenticación</h4>
                    <p>{{ message or 'El email o la contraseña son incorrectos. Por favor, inténtalo de nuevo.' }}</p>
                </div>
            </div>
        {% endif %}

        {% if success %}
            <div class="alert-message alert-success">
                <div class="alert-icon">
                    <i class="bi bi-check-circle-fill"></i>
                </div>
                <div class="alert-content">
                    <h4>¡Registro exitoso!</h4>
                    <p>{{ message or 'Cuenta creada correctamente. Ahora puedes iniciar sesión.' }}</p>
                </div>
            </div>
        {% endif %}

        <!-- Login Form -->
        <form method="POST" action="/login" class="auth-form">
            <div class="form-group">
                <label for="email" class="form-label">Email</label>
                <input type="email" 
                       id="email" 
                       name="email" 
                       class="form-input" 
                       placeholder="tu@email.com" 
                       required>
            </div>

            <div class="form-group">
                <label for="contraseña" class="form-label">Contraseña</label>
                <input type="password" 
                       id="contraseña" 
                       name="contraseña" 
                       class="form-input" 
                       placeholder="•••••••" 
                       required>
            </div>

            <button type="submit" class="auth-submit-btn">
                <i class="bi bi-box-arrow-in-right me-2"></i>
                Iniciar Sesión
            </button>
        </form>

        <!-- Divider -->
        <div class="auth-divider">
            <span>o</span>
        </div>

        <!-- Switch to Register -->
        <div class="switch-auth">
            <p>¿No tienes una cuenta?</p>
            <a href="/register">
                <i class="bi bi-person-plus me-2"></i>
                Crear cuenta ahora
            </a>
        </div>

        <!-- Test Account -->
        <div class="test-account">
            <div class="test-title">
                <i class="bi bi-info-circle me-2"></i>
                Cuenta de Prueba
            </div>
            <div class="test-info">
                Usa estas credenciales para probar la aplicación:
            </div>
            <div class="test-credentials">
                Email: anas@gmail.com<br>
                Contraseña: password123
            </div>
        </div>
    </div>
</div>

<script>
// Add ripple effect to button
document.querySelector('.auth-submit-btn').addEventListener('click', function(e) {
    const ripple = document.createElement('span');
    const rect = this.getBoundingClientRect();
    const size = Math.max(rect.width, rect.height);
    const x = e.clientX - rect.left - size / 2;
    const y = e.clientY - rect.top - size / 2;
    
    ripple.style.width = ripple.style.height = size + 'px';
    ripple.style.left = x + 'px';
    ripple.style.top = y + 'px';
    ripple.classList.add('ripple');
    
    this.appendChild(ripple);
    
    setTimeout(() => {
        ripple.remove();
    }, 600);
});
</script>

<style>
.ripple {
    position: absolute;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.3);
    transform: scale(0);
    animation: ripple-animation 0.6s ease-out;
    pointer-events: none;
}

@keyframes ripple-animation {
    to {
        transform: scale(4);
        opacity: 0;
    }
}
</style>
{% endblock %}
