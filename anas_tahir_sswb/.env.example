# ============================================================
# Tienda Prado — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# ── Database ─────────────────────────────────────────────────
POSTGRES_USER=yo
POSTGRES_PASSWORD=change_me_please
POSTGRES_DB=ssbw
DATABASE_URL=postgresql://yo:change_me_please@localhost:5432/ssbw?schema=public

# ── Server ───────────────────────────────────────────────────
PORT=3000
IN=development

# ── Security ─────────────────────────────────────────────────
# Generate a strong random key: openssl rand -base64 32
SECRET_KEY=generate_a_strong_random_key_here
SESSION_SECRET=generate_another_strong_key_here

# ── Optional Services ─────────────────────────────────────────
# Cloudinary (for image uploads)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# Email (Resend)
# RESEND_API_KEY=your_resend_api_key
