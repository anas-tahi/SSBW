<script>
document.addEventListener('DOMContentLoaded', function() {
    // Quantity selector sync
    const quantityInput = document.getElementById('quantityInput');
    const hiddenQuantity = document.getElementById('hiddenQuantity');
    
    quantityInput.addEventListener('input', function() {
        hiddenQuantity.value = this.value;
    });
    
    // Gallery thumbnail interactions
    const galleryThumbs = document.querySelectorAll('.gallery-thumb');
    const mainImage = document.querySelector('.image-main');
    
    galleryThumbs.forEach((thumb, index) => {
        thumb.addEventListener('click', function() {
            // Add active state
            galleryThumbs.forEach(t => t.style.opacity = '0.6');
            this.style.opacity = '1';
            
            // In a real implementation, this would change the main image
            console.log('Gallery thumb clicked:', index);
        });
    });
    
    // Share button interactions
    const shareButtons = document.querySelectorAll('.share-btn');
    
    shareButtons.forEach(btn => {
        btn.addEventListener('click', function() {
            const platform = this.classList[1];
            const url = window.location.href;
            const title = document.querySelector('.product-title').textContent;
            
            let shareUrl = '';
            
            switch(platform) {
                case 'facebook':
                    shareUrl = `https://www.facebook.com/sharer/sharer.php?u=${url}`;
                    break;
                case 'twitter':
                    shareUrl = `https://twitter.com/intent/tweet?url=${url}&text=${title}`;
                    break;
                case 'whatsapp':
                    shareUrl = `https://wa.me/?text=${title} ${url}`;
                    break;
                case 'link':
                    navigator.clipboard.writeText(url);
                    alert('Enlace copiado al portapapeles');
                    return;
            }
            
            if (shareUrl) {
                window.open(shareUrl, '_blank', 'width=600,height=400');
            }
        });
    });
    
    // Wishlist button
    const wishlistBtn = document.querySelector('.wishlist-btn');
    let isWishlisted = false;
    
    wishlistBtn.addEventListener('click', function() {
        isWishlisted = !isWishlisted;
        
        if (isWishlisted) {
            this.innerHTML = '<i class="bi bi-heart-fill"></i>';
            this.style.background = 'rgba(201, 168, 76, 0.2)';
            this.style.borderColor = '#c9a84c';
            this.style.color = '#c9a84c';
        } else {
            this.innerHTML = '<i class="bi bi-heart"></i>';
            this.style.background = 'rgba(255, 255, 255, 0.05)';
            this.style.borderColor = 'rgba(255, 255, 255, 0.2)';
            this.style.color = '#b8b8d1';
        }
    });
    
    // Smooth scroll for related products
    const relatedCards = document.querySelectorAll('.related-card');
    
    relatedCards.forEach(card => {
        card.addEventListener('click', function() {
            // In a real implementation, this would navigate to the product
            console.log('Related product clicked');
        });
    });
    
    // Login prompt function
    function showLoginPrompt() {
        if (confirm('Para comprar productos, necesitas iniciar sesión.\n\n¿Deseas ir a la página de login ahora?')) {
            window.location.href = '/login';
        }
    }
});
</script>
