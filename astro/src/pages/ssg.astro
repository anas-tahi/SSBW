---
import Layout from '../layouts/Layout.astro';
import CardProducto from '../components/CardProducto.astro';
import productosData from '../../data/productos.json';

const p = productosData.slice(0, 12);
---
<Layout title="Destacados — Tienda Prado">
  <div style="min-height:100vh; background:#f9fafb; padding:3rem 1rem;">
    <div style="max-width:1200px; margin:0 auto;">
      <div style="text-align:center; margin-bottom:2.5rem;">
        <h1 style="font-size:3rem; color:#374151; letter-spacing:0.2em; margin-bottom:0.5rem;">Destacados</h1>
        <p style="color:#6b7280;">Una seleccion de nuestros productos mas especiales</p>
      </div>
      <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(220px, 1fr)); gap:1.5rem;">
        {p.map((producto, i) => (
          <CardProducto
            titulo={producto.título}
            texto_precio={producto.texto_precio}
            imagen={producto.imagen}
            index={i}
          />
        ))}
      </div>
    </div>
  </div>
</Layout>
