{% extends "base.njk" %}

{% block head %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
body { 
    background: #0a0a0f !important; 
    color: #f0f0f0; 
    font-family: 'Outfit', sans-serif;
    overflow-x: hidden;
}

/* Animated Background */
.contact-bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #0a0a0f 0%, #1a1a2e 50%, #16213e 100%);
    z-index: -2;
}

.contact-bg::before {
    content: '';
    position: absolute;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(76, 175, 80, 0.15) 0%, transparent 70%);
    top: -200px;
    left: -150px;
    border-radius: 50%;
    filter: blur(100px);
    animation: floatBlob 20s ease-in-out infinite alternate;
}

.contact-bg::after {
    content: '';
    position: absolute;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(120, 119, 198, 0.15) 0%, transparent 70%);
    bottom: -100px;
    right: -100px;
    border-radius: 50%;
    filter: blur(80px);
    animation: floatBlob 25s ease-in-out infinite alternate-reverse;
}

@keyframes floatBlob {
    0% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(60px, 80px) scale(1.1); }
    100% { transform: translate(30px, 40px) scale(1); }
}

/* Main Container */
.contact-container {
    min-height: 100vh;
    padding: 40px 20px;
    position: relative;
    z-index: 1;
}

/* Contact Header */
.contact-header {
    text-align: center;
    margin-bottom: 60px;
    animation: slideDown 0.8s ease-out;
}

@keyframes slideDown {
    from {
        opacity: 0;
        transform: translateY(-50px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.contact-icon {
    width: 120px;
    height: 120px;
    background: linear-gradient(135deg, #4CAF50, #81C784);
    border-radius: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 30px;
    font-size: 4rem;
    color: #0a0a0f;
    animation: iconGlow 3s ease-in-out infinite alternate;
    box-shadow: 0 20px 40px rgba(76, 175, 80, 0.3);
}

@keyframes iconGlow {
    0% { transform: scale(1); box-shadow: 0 20px 40px rgba(76, 175, 80, 0.3); }
    100% { transform: scale(1.05); box-shadow: 0 25px 50px rgba(76, 175, 80, 0.5); }
}

.contact-title {
    font-size: 3rem;
    font-weight: 800;
    background: linear-gradient(135deg, #f0f0f0, #4CAF50);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 20px;
}

.contact-subtitle {
    color: #b8b8d1;
    font-size: 1.3rem;
    font-weight: 300;
    max-width: 600px;
    margin: 0 auto;
}

/* Contact Layout */
.contact-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    max-width: 1200px;
    margin: 0 auto;
}

/* Contact Form */
.contact-form-section {
    animation: slideLeft 0.8s ease-out 0.3s both;
}

@keyframes slideLeft {
    from {
        opacity: 0;
        transform: translateX(-50px);
    }
    to {
        opacity: 1;
        transform: translateX(0);
    }
}

.contact-form-card {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 30px;
    padding: 50px;
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.3);
}

.form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 25px;
}

.form-group {
    margin-bottom: 25px;
}

.form-label {
    display: block;
    color: #4CAF50;
    font-weight: 600;
    margin-bottom: 10px;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.input-group {
    position: relative;
    display: flex;
    align-items: center;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 15px;
    overflow: hidden;
}

.input-group-icon {
    position: absolute;
    left: 20px;
    color: #b8b8d1;
    font-size: 1.1rem;
    z-index: 1;
}

.form-input,
.form-textarea,
.form-select {
    width: 100%;
    padding: 18px 20px 18px 50px;
    background: rgba(255, 255, 255, 0.05);
    border: none;
    border-radius: 15px;
    color: #f0f0f0;
    font-size: 1rem;
    transition: all 0.3s ease;
    font-family: 'Outfit', sans-serif;
}

.form-textarea {
    resize: vertical;
    min-height: 120px;
    padding: 18px 20px 18px 50px;
}

.form-input::placeholder,
.form-textarea::placeholder {
    color: rgba(255, 255, 255, 0.3);
}

.form-input:focus,
.form-textarea:focus,
.form-select:focus {
    outline: none;
    background: rgba(255, 255, 255, 0.08);
    box-shadow: 0 0 20px rgba(76, 175, 80, 0.3);
    transform: translateY(-2px);
}

.form-select {
    padding: 18px 20px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 15px;
    color: #f0f0f0;
    cursor: pointer;
}

.form-select option {
    background: #0a0a0f;
    color: #f0f0f0;
}

.submit-button {
    width: 100%;
    padding: 20px;
    background: linear-gradient(135deg, #4CAF50, #81C784);
    color: #0a0a0f;
    border: none;
    border-radius: 15px;
    font-size: 1.2rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
    margin-top: 30px;
}

.submit-button::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
    transition: left 0.5s ease;
}

.submit-button:hover::before {
    left: 100%;
}

.submit-button:hover {
    transform: translateY(-3px);
    box-shadow: 0 20px 40px rgba(76, 175, 80, 0.4);
}

/* Contact Info */
.contact-info-section {
    animation: slideRight 0.8s ease-out 0.5s both;
}

@keyframes slideRight {
    from {
        opacity: 0;
        transform: translateX(50px);
    }
    to {
        opacity: 1;
        transform: translateX(0);
    }
}

.contact-info-card {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 30px;
    padding: 50px;
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.3);
}

.contact-info-title {
    font-size: 2rem;
    font-weight: 700;
    color: #f0f0f0;
    margin-bottom: 30px;
}

.contact-info-grid {
    display: grid;
    gap: 30px;
}

.contact-info-item {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    padding: 25px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 20px;
    transition: all 0.3s ease;
}

.contact-info-item:hover {
    background: rgba(76, 175, 80, 0.05);
    border-color: rgba(76, 175, 80, 0.2);
    transform: translateY(-3px);
}

.contact-info-icon {
    width: 60px;
    height: 60px;
    background: linear-gradient(135deg, #4CAF50, #81C784);
    border-radius: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    color: #0a0a0f;
    flex-shrink: 0;
}

.contact-info-content h3 {
    font-size: 1.2rem;
    font-weight: 700;
    color: #4CAF50;
    margin-bottom: 10px;
}

.contact-info-content p {
    color: #b8b8d1;
    line-height: 1.6;
    margin: 0;
}

.contact-info-content a {
    color: #4CAF50;
    text-decoration: none;
    transition: all 0.3s ease;
}

.contact-info-content a:hover {
    color: #81C784;
    text-shadow: 0 0 10px rgba(76, 175, 80, 0.5);
}

/* Business Hours */
.business-hours {
    margin-top: 40px;
    padding: 30px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 20px;
}

.business-hours-title {
    font-size: 1.3rem;
    font-weight: 700;
    color: #f0f0f0;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
}

.business-hours-list {
    list-style: none;
    padding: 0;
    margin: 0;
}

.business-hours-list li {
    display: flex;
    justify-content: space-between;
    padding: 12px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    color: #b8b8d1;
}

.business-hours-list li:last-child {
    border-bottom: none;
}

.business-hours-list li strong {
    color: #f0f0f0;
}

/* Alert Messages */
.alert-message {
    padding: 20px 25px;
    border-radius: 15px;
    margin-bottom: 30px;
    display: flex;
    align-items: center;
    gap: 15px;
    animation: alertSlide 0.5s ease-out;
}

@keyframes alertSlide {
    from {
        opacity: 0;
        transform: translateY(-20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.alert-success {
    background: rgba(76, 175, 80, 0.1);
    border: 1px solid rgba(76, 175, 80, 0.3);
    color: #4CAF50;
}

.alert-error {
    background: rgba(244, 67, 54, 0.1);
    border: 1px solid rgba(244, 67, 54, 0.3);
    color: #f44336;
}

.alert-icon {
    font-size: 1.5rem;
}

.alert-content h4 {
    margin: 0 0 5px 0;
    font-weight: 700;
}

.alert-content p {
    margin: 0;
    font-size: 0.9rem;
}

/* Responsive Design */
@media (max-width: 968px) {
    .contact-layout {
        grid-template-columns: 1fr;
        gap: 40px;
    }
    
    .form-row {
        grid-template-columns: 1fr;
        gap: 15px;
    }
    
    .contact-form-card,
    .contact-info-card {
        padding: 30px;
    }
}

@media (max-width: 768px) {
    .contact-title {
        font-size: 2rem;
    }
    
    .contact-icon {
        width: 80px;
        height: 80px;
        font-size: 3rem;
    }
    
    .contact-form-card,
    .contact-info-card {
        padding: 25px;
        margin: 0 10px;
    }
    
    .contact-info-item {
        flex-direction: column;
        text-align: center;
        gap: 15px;
    }
}
</style>
{% endblock %}

{% block content %}
<div class="contact-bg"></div>

<div class="contact-container">
    <!-- Contact Header -->
    <div class="contact-header">
        <div class="contact-icon">
            <i class="bi bi-envelope-fill"></i>
        </div>
        <h1 class="contact-title">Contacto</h1>
        <p class="contact-subtitle">Estamos aquí para ayudarte con cualquier consulta sobre nuestras obras de arte</p>
    </div>

    <!-- Contact Layout -->
    <div class="contact-layout">
        <!-- Contact Form -->
        <div class="contact-form-section">
            <div class="contact-form-card">
                <!-- Alert Messages -->
                {% if success %}
                    <div class="alert-message alert-success">
                        <div class="alert-icon">
                            <i class="bi bi-check-circle-fill"></i>
                        </div>
                        <div class="alert-content">
                            <h4>¡Mensaje enviado!</h4>
                            <p>{{ success }}</p>
                        </div>
                    </div>
                {% endif %}
                
                {% if error %}
                    <div class="alert-message alert-error">
                        <div class="alert-icon">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                        </div>
                        <div class="alert-content">
                            <h4>Error al enviar</h4>
                            <p>{{ error }}</p>
                        </div>
                    </div>
                {% endif %}

                <form method="POST" action="/contacto">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="nombre" class="form-label">Nombre Completo</label>
                            <div class="input-group">
                                <span class="input-group-icon">
                                    <i class="bi bi-person"></i>
                                </span>
                                <input type="text" 
                                       id="nombre" 
                                       name="nombre" 
                                       class="form-input" 
                                       placeholder="Tu nombre completo"
                                       value="{{ formData.nombre or '' }}"
                                       required>
                            </div>
                        </div>
                        
                        <div class="form-group">
                            <label for="email" class="form-label">Email</label>
                            <div class="input-group">
                                <span class="input-group-icon">
                                    <i class="bi bi-envelope"></i>
                                </span>
                                <input type="email" 
                                       id="email" 
                                       name="email" 
                                       class="form-input" 
                                       placeholder="tu@email.com"
                                       value="{{ formData.email or '' }}"
                                       required>
                            </div>
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label for="asunto" class="form-label">Asunto</label>
                        <div class="input-group">
                            <span class="input-group-icon">
                                <i class="bi bi-chat-dots"></i>
                            </span>
                            <input type="text" 
                                   id="asunto" 
                                   name="asunto" 
                                   class="form-input" 
                                   placeholder="¿Sobre qué es tu consulta?"
                                   required>
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label for="tipo" class="form-label">Tipo de Consulta</label>
                        <select id="tipo" name="tipo" class="form-select" required>
                            <option value="">Selecciona un tipo...</option>
                            <option value="general">Consulta General</option>
                            <option value="producto">Información de Producto</option>
                            <option value="pedido">Estado de Pedido</option>
                            <option value="devolucion">Devoluciones</option>
                            <option value="colaboracion">Colaboración Artística</option>
                            <option value="tecnico">Problema Técnico</option>
                        </select>
                    </div>
                    
                    <div class="form-group">
                        <label for="mensaje" class="form-label">Mensaje</label>
                        <div class="input-group">
                            <span class="input-group-icon" style="position: absolute; top: 18px;">
                                <i class="bi bi-chat-text"></i>
                            </span>
                            <textarea id="mensaje" 
                                      name="mensaje" 
                                      class="form-textarea" 
                                      placeholder="Cuéntanos más detalles sobre tu consulta..."
                                      rows="5" 
                                      required></textarea>
                        </div>
                    </div>
                    
                    <button type="submit" class="submit-button">
                        <i class="bi bi-send me-2"></i>
                        Enviar Mensaje
                    </button>
                </form>
            </div>
        </div>

        <!-- Contact Info -->
        <div class="contact-info-section">
            <div class="contact-info-card">
                <h2 class="contact-info-title">Información de Contacto</h2>
                
                <div class="contact-info-grid">
                    <div class="contact-info-item">
                        <div class="contact-info-icon">
                            <i class="bi bi-geo-alt-fill"></i>
                        </div>
                        <div class="contact-info-content">
                            <h3>Dirección</h3>
                            <p>
                                Calle del Prado, 123<br>
                                28014 Madrid, España<br>
                                Junto al Museo del Prado
                            </p>
                        </div>
                    </div>
                    
                    <div class="contact-info-item">
                        <div class="contact-info-icon">
                            <i class="bi bi-telephone-fill"></i>
                        </div>
                        <div class="contact-info-content">
                            <h3>Teléfono</h3>
                            <p>
                                <a href="tel:+34911234567">+34 91 123 4567</a><br>
                                <a href="tel:+34600123456">+34 600 123 456</a>
                            </p>
                        </div>
                    </div>
                    
                    <div class="contact-info-item">
                        <div class="contact-info-icon">
                            <i class="bi bi-envelope-fill"></i>
                        </div>
                        <div class="contact-info-content">
                            <h3>Email</h3>
                            <p>
                                <a href="mailto:info@tiendaprado.com">info@tiendaprado.com</a><br>
                                <a href="mailto:contacto@tiendaprado.com">contacto@tiendaprado.com</a>
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Business Hours -->
                <div class="business-hours">
                    <h3 class="business-hours-title">
                        <i class="bi bi-clock-fill"></i>
                        Horario de Atención
                    </h3>
                    <ul class="business-hours-list">
                        <li><strong>Lunes a Viernes:</strong> 9:00 - 18:00</li>
                        <li><strong>Sábados:</strong> 10:00 - 14:00</li>
                        <li><strong>Domingos:</strong> Cerrado</li>
                        <li><strong>Respuesta email:</strong> 24 horas</li>
                    </ul>
                </div>

                <!-- Additional Info -->
                <div class="business-hours" style="margin-top: 30px;">
                    <h3 class="business-hours-title">
                        <i class="bi bi-info-circle-fill"></i>
                        Información Adicional
                    </h3>
                    <div style="display: grid; gap: 15px;">
                        <div>
                            <strong style="color: #4CAF50;">Envíos:</strong>
                            <p style="color: #b8b8d1; margin: 5px 0;">Envíos a toda España en 24-48h</p>
                        </div>
                        <div>
                            <strong style="color: #4CAF50;">Pagos:</strong>
                            <p style="color: #b8b8d1; margin: 5px 0;">Aceptamos tarjeta, PayPal y transferencia</p>
                        </div>
                        <div>
                            <strong style="color: #4CAF50;">Garantía:</strong>
                            <p style="color: #b8b8d1; margin: 5px 0;">30 días de garantía en todas las obras</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
// Add ripple effect to submit button
document.querySelector('.submit-button').addEventListener('click', function(e) {
    const ripple = document.createElement('span');
    const rect = this.getBoundingClientRect();
    const size = Math.max(rect.width, rect.height);
    const x = e.clientX - rect.left - size / 2;
    const y = e.clientY - rect.top - size / 2;
    
    ripple.style.width = ripple.style.height = size + 'px';
    ripple.style.left = x + 'px';
    ripple.style.top = y + 'px';
    ripple.classList.add('ripple');
    
    this.appendChild(ripple);
    
    setTimeout(() => {
        ripple.remove();
    }, 600);
});
</script>

<style>
.ripple {
    position: absolute;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.3);
    transform: scale(0);
    animation: ripple-animation 0.6s ease-out;
    pointer-events: none;
}

@keyframes ripple-animation {
    to {
        transform: scale(4);
        opacity: 0;
    }
}
</style>
{% endblock %}
