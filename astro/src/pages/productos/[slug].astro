---
import Layout from '../../layouts/Layout.astro';
import productos from '../../../data/productos.json';

export async function getStaticPaths() {
  return productos.map((pr, index) => ({
    params: { slug: String(index) },
    props: { producto: pr }
  }));
}

const { producto } = Astro.props;
---

<Layout title={`${producto.título} — Tienda Prado`}>
  <div class="min-h-screen bg-gray-50 py-12 px-4">
    <div class="max-w-4xl mx-auto">
      <a href="/ssg" class="text-red-700 hover:underline mb-8 inline-block">← Volver a Destacados</a>
      <div class="bg-white rounded-2xl shadow-lg overflow-hidden grid grid-cols-1 md:grid-cols-2">
        <div class="bg-gray-100 flex items-center justify-center p-8">
          <img src={`/images/${producto.imagen}`} alt={producto.título} class="max-h-80 object-contain rounded-xl" onerror="this.src='https://via.placeholder.com/400x400?text=Tienda+Prado'" />
        </div>
        <div class="p-8 flex flex-col justify-center">
          <h1 class="font-serif text-3xl text-gray-800 mb-4">{producto.título}</h1>
          <p class="text-gray-600 mb-6 leading-relaxed">{producto.descripción}</p>
          <p class="text-2xl font-bold text-red-700 mb-6">{producto.texto_precio}</p>
          <button class="bg-red-700 text-white px-8 py-3 rounded-lg font-semibold hover:bg-red-800 transition-colors">
            Añadir al carrito
          </button>
        </div>
      </div>
    </div>
  </div>
</Layout>
