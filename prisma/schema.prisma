// =======================
//   Prisma Client Setup
// =======================

generator client {
  provider = "prisma-client-js"
}

// =======================
//     Database Provider
// =======================
// Prisma 7: NO URL HERE.
// URL is defined in prisma.config.ts

datasource db {
  provider = "sqlite"
}

// =======================
//        MODELS
// =======================

// USERS
model Usuario {
  email            String   @id
  nombre           String
  contraseña       String
  admin            Boolean  @default(false)

  telefono         String?
  direccion        String?
  fecha_nacimiento DateTime?
  genero           String?
  biografia        String?
  idioma           String   @default("es")
  newsletter       Boolean  @default(false)
  creado_en        DateTime @default(now())
  actualizado_en   DateTime?

  @@map("usuarios")
}

// PRODUCTS
model Producto {
  id          Int     @id @default(autoincrement())
  título      String
  descripción String
  precio      Float
  imagen      String

  @@map("productos")
}
