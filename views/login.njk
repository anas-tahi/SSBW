{% extends "base.njk" %}

{% block head %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body { 
    background: #0a0a0f; 
    color: #ffffff; 
    font-family: 'Inter', sans-serif;
    overflow-x: hidden;
    min-height: 100vh;
}

/* Modern Animated Background */
.modern-bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: 
        radial-gradient(circle at 20% 50%, rgba(201, 168, 76, 0.3) 0%, transparent 50%),
        radial-gradient(circle at 80% 80%, rgba(120, 119, 198, 0.25) 0%, transparent 50%),
        radial-gradient(circle at 40% 20%, rgba(76, 175, 80, 0.2) 0%, transparent 50%),
        linear-gradient(135deg, #0a0a0f 0%, #1a1a2e 50%, #16213e 100%);
    z-index: -2;
}

.floating-orbs {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    overflow: hidden;
}

.orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.6;
    animation: float 20s ease-in-out infinite;
}

.orb1 {
    width: 400px;
    height: 400px;
    background: linear-gradient(135deg, #c9a84c, #e8d070);
    top: -100px;
    left: -100px;
    animation-delay: 0s;
}

.orb2 {
    width: 350px;
    height: 350px;
    background: linear-gradient(135deg, #7877c6, #a8a4ff);
    bottom: -100px;
    right: -100px;
    animation-delay: 5s;
}

.orb3 {
    width: 300px;
    height: 300px;
    background: linear-gradient(135deg, #4CAF50, #81C784);
    top: 50%;
    left: 50%;
    animation-delay: 10s;
}

@keyframes float {
    0%, 100% { transform: translate(0, 0) scale(1); }
    25% { transform: translate(100px, 50px) scale(1.1); }
    50% { transform: translate(-50px, 100px) scale(0.9); }
    75% { transform: translate(50px, -50px) scale(1.05); }
}

/* Main Container */
.auth-container {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
    position: relative;
    z-index: 1;
}

/* Modern Auth Card */
.auth-card {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(40px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 40px;
    padding: 60px;
    max-width: 480px;
    width: 100%;
    animation: slideUp 1s ease-out;
    box-shadow: 
        0 30px 60px rgba(0, 0, 0, 0.4),
        inset 0 1px 0 rgba(255, 255, 255, 0.1);
    position: relative;
    overflow: hidden;
}

.auth-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
    animation: shimmer 3s ease-in-out infinite;
}

@keyframes shimmer {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
}

@keyframes slideUp {
    from {
        opacity: 0;
        transform: translateY(60px) scale(0.9);
    }
    to {
        opacity: 1;
        transform: translateY(0) scale(1);
    }
}

/* Modern Header */
.auth-header {
    text-align: center;
    margin-bottom: 50px;
}

.auth-icon {
    width: 80px;
    height: 80px;
    background: linear-gradient(135deg, #c9a84c, #e8d070);
    border-radius: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 25px;
    font-size: 2.5rem;
    color: #0a0a0f;
    animation: iconFloat 4s ease-in-out infinite;
    box-shadow: 
        0 20px 40px rgba(201, 168, 76, 0.3),
        0 0 0 1px rgba(201, 168, 76, 0.1);
}

@keyframes iconFloat {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-10px) scale(1.05); }
}

.auth-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 2.8rem;
    font-weight: 700;
    background: linear-gradient(135deg, #ffffff, #c9a84c, #e8d070);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 12px;
    letter-spacing: -0.02em;
}

.auth-subtitle {
    color: rgba(255, 255, 255, 0.6);
    font-size: 1.1rem;
    font-weight: 400;
    letter-spacing: 0.02em;
}

/* Modern Form Styles */
.auth-form {
    margin-bottom: 40px;
}

.form-group {
    margin-bottom: 24px;
    position: relative;
}

.form-label {
    display: block;
    color: rgba(255, 255, 255, 0.8);
    font-weight: 500;
    margin-bottom: 8px;
    font-size: 0.9rem;
    letter-spacing: 0.02em;
}

.input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
}

.form-input {
    width: 100%;
    padding: 16px 20px 16px 50px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    color: #ffffff;
    font-size: 1rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    font-family: 'Inter', sans-serif;
    font-weight: 400;
}

.form-input::placeholder {
    color: rgba(255, 255, 255, 0.3);
}

.form-input:focus {
    outline: none;
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(201, 168, 76, 0.5);
    box-shadow: 
        0 0 0 4px rgba(201, 168, 76, 0.1),
        0 10px 30px rgba(201, 168, 76, 0.2);
    transform: translateY(-2px);
}

.input-icon {
    position: absolute;
    left: 20px;
    color: rgba(255, 255, 255, 0.4);
    font-size: 1.1rem;
    transition: all 0.3s ease;
    pointer-events: none;
}

.form-input:focus + .input-icon {
    color: #c9a84c;
    transform: scale(1.1);
}

/* Modern Submit Button */
.auth-submit-btn {
    width: 100%;
    padding: 18px;
    background: linear-gradient(135deg, #c9a84c, #e8d070);
    color: #0a0a0f;
    border: none;
    border-radius: 16px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
    margin-top: 32px;
    font-family: 'Inter', sans-serif;
    letter-spacing: 0.02em;
    box-shadow: 
        0 10px 25px rgba(201, 168, 76, 0.3),
        0 0 0 1px rgba(201, 168, 76, 0.1);
}

.auth-submit-btn::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
    transition: left 0.6s ease;
}

.auth-submit-btn:hover::before {
    left: 100%;
}

.auth-submit-btn:hover {
    transform: translateY(-3px);
    box-shadow: 
        0 20px 40px rgba(201, 168, 76, 0.4),
        0 0 0 1px rgba(201, 168, 76, 0.2);
    background: linear-gradient(135deg, #b8941f, #d4af37);
}

.auth-submit-btn:active {
    transform: translateY(-1px);
}

/* Modern Alert Messages */
.alert-message {
    padding: 16px 20px;
    border-radius: 12px;
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 12px;
    animation: alertSlide 0.5s ease-out;
    backdrop-filter: blur(10px);
    border: 1px solid;
    font-size: 0.95rem;
}

@keyframes alertSlide {
    from {
        opacity: 0;
        transform: translateY(-20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.alert-success {
    background: rgba(76, 175, 80, 0.1);
    border-color: rgba(76, 175, 80, 0.3);
    color: #4CAF50;
}

.alert-error {
    background: rgba(244, 67, 54, 0.1);
    border-color: rgba(244, 67, 54, 0.3);
    color: #f44336;
}

.alert-icon {
    font-size: 1.2rem;
    flex-shrink: 0;
}

.alert-content h4 {
    margin: 0 0 4px 0;
    font-weight: 600;
    font-size: 1rem;
}

.alert-content p {
    margin: 0;
    font-size: 0.9rem;
    opacity: 0.9;
}

/* Modern Divider */
.auth-divider {
    text-align: center;
    margin: 40px 0;
    position: relative;
}

.auth-divider::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
}

.auth-divider span {
    background: rgba(10, 10, 15, 0.8);
    padding: 0 20px;
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.9rem;
    position: relative;
    z-index: 1;
    font-weight: 400;
}

/* Modern Switch Auth */
.switch-auth {
    text-align: center;
    margin-top: 32px;
}

.switch-auth p {
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 16px;
    font-size: 0.95rem;
}

.switch-auth a {
    color: #c9a84c;
    text-decoration: none;
    font-weight: 500;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: 12px;
    background: rgba(201, 168, 76, 0.1);
    border: 1px solid rgba(201, 168, 76, 0.2);
    font-size: 0.95rem;
}

.switch-auth a:hover {
    color: #e8d070;
    background: rgba(201, 168, 76, 0.2);
    border-color: rgba(201, 168, 76, 0.3);
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(201, 168, 76, 0.2);
}

/* Responsive Design */
@media (max-width: 768px) {
    .auth-card {
        padding: 40px 30px;
        margin: 20px;
        border-radius: 24px;
    }
    
    .auth-title {
        font-size: 2.2rem;
    }
    
    .auth-icon {
        width: 70px;
        height: 70px;
        font-size: 2rem;
    }
    
    .auth-submit-btn {
        padding: 16px;
        font-size: 0.95rem;
    }
}

/* Loading States */
.form-input.loading {
    background: rgba(255, 255, 255, 0.08);
    cursor: not-allowed;
}

/* UX Enhancement Styles */
.clickable-label {
    cursor: pointer;
    transition: color 0.3s ease;
    display: inline-block;
    margin-bottom: 8px;
}

.clickable-label:hover {
    color: #c9a84c;
}

.password-toggle {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.6);
    cursor: pointer;
    padding: 8px;
    border-radius: 6px;
    transition: all 0.3s ease;
    z-index: 2;
}

.password-toggle:hover {
    color: #c9a84c;
    background: rgba(201, 168, 76, 0.1);
}

.password-requirements {
    margin-top: 12px;
    padding: 16px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    font-size: 0.85rem;
    display: none;
}

.password-requirements.show {
    display: block;
    animation: fadeIn 0.3s ease;
}

.password-requirements p {
    margin: 0 0 8px 0;
    color: #c9a84c;
    font-weight: 500;
}

.password-requirements ul {
    margin: 0;
    padding-left: 20px;
    list-style: none;
}

.password-requirements li {
    margin: 4px 0;
    color: rgba(255, 255, 255, 0.6);
    transition: color 0.3s ease;
}

.password-requirements li.valid {
    color: #4CAF50;
}

.password-requirements li.invalid {
    color: #f44336;
}

.field-error {
    margin-top: 8px;
    padding: 8px 12px;
    background: rgba(244, 67, 54, 0.1);
    border: 1px solid rgba(244, 67, 54, 0.3);
    border-radius: 6px;
    color: #f44336;
    font-size: 0.85rem;
    display: none;
    animation: fadeIn 0.3s ease;
}

.field-error.show {
    display: block;
}

.form-input.error {
    border-color: #f44336;
    background: rgba(244, 67, 54, 0.05);
}

.form-input.success {
    border-color: #4CAF50;
    background: rgba(76, 175, 80, 0.05);
}

@keyframes fadeIn {
    from {
        opacity: 0;
        transform: translateY(-5px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.auth-submit-btn.loading {
    background: linear-gradient(135deg, #b8941f, #d4af37);
    cursor: not-allowed;
    opacity: 0.8;
}

/* Success/Error States */
.form-input.success {
    border-color: rgba(201, 168, 76, 0.5);
    background: rgba(201, 168, 76, 0.05);
}

.form-input.success + .input-icon {
    color: #c9a84c;
}

.form-input.error {
    border-color: rgba(244, 67, 54, 0.5);
    background: rgba(244, 67, 54, 0.05);
}

.form-input.error + .input-icon {
    color: #f44336;
}
</style>
{% endblock %}

{% block content %}
<div class="modern-bg"></div>
<div class="floating-orbs">
    <div class="orb orb1"></div>
    <div class="orb orb2"></div>
    <div class="orb orb3"></div>
</div>

<div class="auth-container">
    <div class="auth-card">
        <!-- Header -->
        <div class="auth-header">
            <div class="auth-icon">
                <i class="bi bi-shield-lock-fill"></i>
            </div>
            <h1 class="auth-title">Iniciar Sesión</h1>
            <p class="auth-subtitle">Accede a tu cuenta de Tienda Prado</p>
        </div>

        <!-- Alert Messages -->
        {% if error %}
            <div class="alert-message alert-error">
                <div class="alert-icon">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                </div>
                <div class="alert-content">
                    <h4>Error de autenticación</h4>
                    <p>{{ message or 'El email o la contraseña son incorrectos. Por favor, inténtalo de nuevo.' }}</p>
                </div>
            </div>
        {% endif %}

        {% if success %}
            <div class="alert-message alert-success">
                <div class="alert-icon">
                    <i class="bi bi-check-circle-fill"></i>
                </div>
                <div class="alert-content">
                    <h4>¡Registro exitoso!</h4>
                    <p>{{ message or 'Cuenta creada correctamente. Ahora puedes iniciar sesión.' }}</p>
                </div>
            </div>
        {% endif %}

        <!-- Login Form -->
        <form method="POST" action="/login" class="auth-form" id="loginForm">
            <div class="form-group">
                <label for="email" class="form-label clickable-label">Correo Electrónico</label>
                <div class="input-wrapper">
                    <input type="email" 
                           id="email" 
                           name="email" 
                           class="form-input" 
                           inputmode="email"
                           autocomplete="email"
                           placeholder="tu@email.com" 
                           value="{{ email or '' }}"
                           required
                           autofocus>
                    <span class="input-icon">
                        <i class="bi bi-envelope"></i>
                    </span>
                </div>
                <div class="field-error" id="emailError"></div>
            </div>

            <div class="form-group">
                <label for="contraseña" class="form-label clickable-label">Contraseña</label>
                <div class="input-wrapper">
                    <input type="password" 
                           id="contraseña" 
                           name="contraseña" 
                           class="form-input" 
                           inputmode="text"
                           autocomplete="current-password"
                           placeholder="Introduce tu contraseña segura" 
                           required>
                    <button type="button" class="password-toggle" id="passwordToggle">
                        <i class="bi bi-eye" id="passwordIcon"></i>
                    </button>
                    <span class="input-icon">
                        <i class="bi bi-lock"></i>
                    </span>
                </div>
                <div class="password-requirements" id="passwordRequirements">
                    <p><strong>Requisitos de contraseña:</strong></p>
                    <ul>
                        <li id="req-length">Mínimo 3 caracteres</li>
                        <li id="req-chars">Al menos un carácter especial</li>
                        <li id="req-number">Al menos un número</li>
                    </ul>
                </div>
                <div class="field-error" id="passwordError"></div>
            </div>

            <button type="submit" class="auth-submit-btn" id="submitBtn">
                <i class="bi bi-shield-lock me-2"></i>
                Acceder a mi cuenta
            </button>
        </form>

        <!-- Divider -->
        <div class="auth-divider">
            <span>o</span>
        </div>

        <!-- Switch to Register -->
        <div class="switch-auth">
            <p>¿No tienes una cuenta?</p>
            <a href="/register">
                <i class="bi bi-person-plus me-2"></i>
                Crear cuenta ahora
            </a>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('loginForm');
    const emailInput = document.getElementById('email');
    const passwordInput = document.getElementById('contraseña');
    const submitBtn = document.getElementById('submitBtn');
    const passwordToggle = document.getElementById('passwordToggle');
    const passwordIcon = document.getElementById('passwordIcon');
    const passwordRequirements = document.getElementById('passwordRequirements');
    const emailError = document.getElementById('emailError');
    const passwordError = document.getElementById('passwordError');
    
    // Make labels clickable
    const clickableLabels = document.querySelectorAll('.clickable-label');
    clickableLabels.forEach(label => {
        label.addEventListener('click', function() {
            const targetId = this.getAttribute('for');
            const targetInput = document.getElementById(targetId);
            if (targetInput) {
                targetInput.focus();
            }
        });
    });
    
    // Password toggle functionality
    passwordToggle.addEventListener('click', function() {
        const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
        passwordInput.setAttribute('type', type);
        
        // Update icon
        if (type === 'text') {
            passwordIcon.className = 'bi bi-eye-slash';
        } else {
            passwordIcon.className = 'bi bi-eye';
        }
    });
    
    // Show password requirements when password field is focused
    passwordInput.addEventListener('focus', function() {
        passwordRequirements.classList.add('show');
    });
    
    passwordInput.addEventListener('blur', function() {
        // Hide requirements only if password is valid or empty
        if (this.value === '' || validatePassword(this.value)) {
            passwordRequirements.classList.remove('show');
        }
    });
    
    // Email validation on blur
    emailInput.addEventListener('blur', function() {
        validateEmail();
    });
    
    // Password validation on blur and input
    passwordInput.addEventListener('blur', function() {
        validatePassword(this.value);
    });
    
    passwordInput.addEventListener('input', function() {
        updatePasswordRequirements(this.value);
    });
    
    // Enhanced input interactions
    [emailInput, passwordInput].forEach(input => {
        input.addEventListener('focus', function() {
            this.parentElement.style.transform = 'translateY(-2px)';
        });
        
        input.addEventListener('blur', function() {
            this.parentElement.style.transform = 'translateY(0)';
        });
    });
    
    // Email validation function
    function validateEmail() {
        const email = emailInput.value.trim();
        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        
        // Clear previous state
        emailInput.classList.remove('success', 'error');
        emailError.classList.remove('show');
        
        if (email === '') {
            return true; // Empty field is valid for now
        }
        
        if (!emailRegex.test(email)) {
            emailInput.classList.add('error');
            emailError.textContent = 'Por favor, introduce un email válido (ej: usuario@dominio.com)';
            emailError.classList.add('show');
            return false;
        }
        
        emailInput.classList.add('success');
        return true;
    }
    
    // Password validation function
    function validatePassword(password) {
        const minLength = 3;
        const hasSpecialChar = /[!@#$%^&*(),.?":{}|<>]/.test(password);
        const hasNumber = /\d/.test(password);
        
        // Clear previous state
        passwordInput.classList.remove('success', 'error');
        passwordError.classList.remove('show');
        
        if (password === '') {
            return true; // Empty field is valid for now
        }
        
        if (password.length < minLength) {
            passwordInput.classList.add('error');
            passwordError.textContent = 'La contraseña debe tener al menos 3 caracteres';
            passwordError.classList.add('show');
            return false;
        }
        
        passwordInput.classList.add('success');
        return true;
    }
    
    // Update password requirements display
    function updatePasswordRequirements(password) {
        const minLength = 3;
        const hasSpecialChar = /[!@#$%^&*(),.?":{}|<>]/.test(password);
        const hasNumber = /\d/.test(password);
        
        const reqLength = document.getElementById('req-length');
        const reqChars = document.getElementById('req-chars');
        const reqNumber = document.getElementById('req-number');
        
        // Update length requirement
        if (password.length >= minLength) {
            reqLength.classList.add('valid');
            reqLength.classList.remove('invalid');
        } else {
            reqLength.classList.add('invalid');
            reqLength.classList.remove('valid');
        }
        
        // Update special character requirement
        if (hasSpecialChar) {
            reqChars.classList.add('valid');
            reqChars.classList.remove('invalid');
        } else {
            reqChars.classList.add('invalid');
            reqChars.classList.remove('valid');
        }
        
        // Update number requirement
        if (hasNumber) {
            reqNumber.classList.add('valid');
            reqNumber.classList.remove('invalid');
        } else {
            reqNumber.classList.add('invalid');
            reqNumber.classList.remove('valid');
        }
    }
    
    // Form submission
    form.addEventListener('submit', function(e) {
        e.preventDefault();
        
        // Validate all fields
        const isEmailValid = validateEmail();
        const isPasswordValid = validatePassword(passwordInput.value);
        
        if (!isEmailValid || !isPasswordValid) {
            // Shake animation for invalid form
            form.style.animation = 'shake 0.5s';
            setTimeout(() => {
                form.style.animation = '';
            }, 500);
            
            // Show general error message
            if (!isEmailValid && !isPasswordValid) {
                emailError.textContent = 'Por favor, corrige los errores del formulario';
                emailError.classList.add('show');
            }
            return;
        }
        
        // Show loading state
        submitBtn.classList.add('loading');
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<i class="bi bi-hourglass-split me-2"></i>Accediendo...';
        
        // Submit form
        form.submit();
    });
    
    // Add shake animation
    const style = document.createElement('style');
    style.textContent = `
        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-10px); }
            75% { transform: translateX(10px); }
        }
    `;
    document.head.appendChild(style);
});
</script>
{% endblock %}
