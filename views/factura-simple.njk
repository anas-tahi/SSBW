{% extends "base.njk" %}

{% block head %}
<style>
.invoice-container {
    max-width: 900px;
    margin: 40px auto;
    background: linear-gradient(135deg, 
        rgba(10, 10, 15, 0.9) 0%, 
        rgba(26, 26, 46, 0.9) 50%, 
        rgba(22, 33, 62, 0.9) 100%);
    backdrop-filter: blur(20px);
    border-radius: 20px;
    padding: 40px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
    border: 1px solid rgba(201, 168, 76, 0.2);
}

.invoice-header {
    text-align: center;
    margin-bottom: 40px;
    padding-bottom: 20px;
    border-bottom: 2px solid rgba(201, 168, 76, 0.3);
}

.invoice-title {
    font-size: 2.5rem;
    font-weight: 700;
    background: linear-gradient(135deg, #c9a84c, #e8d070);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 10px;
}

.invoice-subtitle {
    color: #b8b8d1;
    font-size: 1.2rem;
}

.invoice-info {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
    margin-bottom: 30px;
}

.info-section {
    background: rgba(255, 255, 255, 0.05);
    padding: 20px;
    border-radius: 15px;
    border: 1px solid rgba(255, 255, 255, 0.1);
}

.info-title {
    color: #c9a84c;
    font-weight: 600;
    margin-bottom: 15px;
    font-size: 1.1rem;
}

.info-item {
    margin-bottom: 8px;
    color: #f0f0f0;
}

.invoice-table {
    width: 100%;
    border-collapse: collapse;
    margin: 30px 0;
    background: rgba(255, 255, 255, 0.02);
    border-radius: 15px;
    overflow: hidden;
}

.invoice-table th {
    background: rgba(201, 168, 76, 0.2);
    color: #f0f0f0;
    padding: 15px;
    text-align: left;
    font-weight: 600;
}

.invoice-table td {
    padding: 15px;
    color: #f0f0f0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

.invoice-table tr:last-child td {
    border-bottom: none;
}

.invoice-totals {
    display: flex;
    justify-content: flex-end;
    margin-top: 30px;
}

.totals-section {
    background: rgba(201, 168, 76, 0.1);
    padding: 20px 30px;
    border-radius: 15px;
    border: 1px solid rgba(201, 168, 76, 0.3);
    min-width: 300px;
}

.total-row {
    display: flex;
    justify-content: space-between;
    margin-bottom: 10px;
    color: #f0f0f0;
}

.total-row.grand-total {
    font-size: 1.3rem;
    font-weight: 700;
    color: #c9a84c;
    margin-top: 15px;
    padding-top: 15px;
    border-top: 2px solid rgba(201, 168, 76, 0.3);
}

.action-buttons {
    display: flex;
    gap: 20px;
    justify-content: center;
    margin-top: 40px;
}

.btn-download {
    padding: 15px 30px;
    background: linear-gradient(135deg, #c9a84c, #e8d070);
    color: #0a0a0f;
    border: none;
    border-radius: 25px;
    font-size: 1.1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 10px;
}

.btn-download:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(201, 168, 76, 0.3);
}

.btn-back {
    padding: 15px 30px;
    background: rgba(255, 255, 255, 0.1);
    color: #f0f0f0;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 25px;
    font-size: 1.1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 10px;
}

.btn-back:hover {
    background: rgba(255, 255, 255, 0.2);
    transform: translateY(-2px);
}

@media (max-width: 768px) {
    .invoice-container {
        margin: 20px;
        padding: 20px;
    }
    
    .invoice-info {
        grid-template-columns: 1fr;
        gap: 20px;
    }
    
    .invoice-title {
        font-size: 2rem;
    }
    
    .action-buttons {
        flex-direction: column;
        align-items: center;
    }
    
    .btn-download, .btn-back {
        width: 100%;
        justify-content: center;
    }
}
</style>
{% endblock %}

{% block content %}
<div class="invoice-container">
    <!-- Invoice Header -->
    <div class="invoice-header">
        <h1 class="invoice-title">Factura</h1>
        <p class="invoice-subtitle">Número: {{ invoice_number || 'N/A' }}</p>
    </div>

    <!-- Invoice Information -->
    <div class="invoice-info">
        <!-- Customer Info -->
        <div class="info-section">
            <h3 class="info-title">Información del Cliente</h3>
            <div class="info-item"><strong>Nombre:</strong> {{ cardholder || 'N/A' }}</div>
            <div class="info-item"><strong>Email:</strong> {{ email || 'N/A' }}</div>
            <div class="info-item"><strong>Tarjeta:</strong> **** **** **** {{ card_last4 || 'N/A' }}</div>
        </div>

        <!-- Invoice Details -->
        <div class="info-section">
            <h3 class="info-title">Detalles de la Factura</h3>
            <div class="info-item"><strong>Fecha:</strong> {{ payment_date || new Date().toLocaleDateString() }}</div>
            <div class="info-item"><strong>Método de Pago:</strong> Tarjeta de Crédito</div>
            <div class="info-item"><strong>Estado:</strong> Pagado</div>
        </div>
    </div>

    <!-- Invoice Items -->
    {% if carrito and carrito.items and carrito.items.length > 0 %}
    <table class="invoice-table">
        <thead>
            <tr>
                <th>Producto</th>
                <th>Cantidad</th>
                <th>Precio Unitario</th>
                <th>Subtotal</th>
            </tr>
        </thead>
        <tbody>
            {% for item in carrito.items %}
            <tr>
                <td>{{ item.nombre || item.título || 'Producto' }}</td>
                <td>{{ item.cantidad || 1 }}</td>
                <td>€{{ item.precio || 0 }}</td>
                <td>€{{ ((item.precio || 0) * (item.cantidad || 1)) }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% else %}
    <div style="text-align: center; padding: 40px; color: #b8b8d1;">
        <p>No hay productos en esta factura</p>
    </div>
    {% endif %}

    <!-- Invoice Totals -->
    {% if total %}
    <div class="invoice-totals">
        <div class="totals-section">
            <div class="total-row">
                <span>Subtotal:</span>
                <span>€{{ (parseFloat(total) * 0.79).toFixed(2) }}</span>
            </div>
            <div class="total-row">
                <span>IVA (21%):</span>
                <span>€{{ (parseFloat(total) * 0.21).toFixed(2) }}</span>
            </div>
            <div class="total-row">
                <span>Envío:</span>
                <span>€0.00</span>
            </div>
            <div class="total-row grand-total">
                <span>Total:</span>
                <span>€{{ total }}</span>
            </div>
        </div>
    </div>
    {% endif %}

    <!-- Action Buttons -->
    <div class="action-buttons">
        <a href="/descargar-factura" class="btn-download">
            <i class="bi bi-download"></i>
            Descargar PDF
        </a>
        <a href="/" class="btn-back">
            <i class="bi bi-house"></i>
            Volver a la Tienda
        </a>
    </div>
</div>
{% endblock %}
