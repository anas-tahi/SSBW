{% extends "base.njk" %}

{% block head %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body { 
    background: #0a0a0f; 
    color: #ffffff; 
    font-family: 'Inter', sans-serif;
    overflow-x: hidden;
    min-height: 100vh;
}

/* Modern Animated Background */
.modern-bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: 
        radial-gradient(circle at 20% 50%, rgba(120, 119, 198, 0.3) 0%, transparent 50%),
        radial-gradient(circle at 80% 80%, rgba(76, 175, 80, 0.25) 0%, transparent 50%),
        radial-gradient(circle at 40% 20%, rgba(255, 119, 168, 0.2) 0%, transparent 50%),
        linear-gradient(135deg, #0a0a0f 0%, #1a1a2e 50%, #16213e 100%);
    z-index: -2;
}

.floating-orbs {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    overflow: hidden;
}

.orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.6;
    animation: float 20s ease-in-out infinite;
}

.orb1 {
    width: 400px;
    height: 400px;
    background: linear-gradient(135deg, #4CAF50, #81C784);
    top: -100px;
    left: -100px;
    animation-delay: 0s;
}

.orb2 {
    width: 350px;
    height: 350px;
    background: linear-gradient(135deg, #7877c6, #a8a4ff);
    bottom: -100px;
    right: -100px;
    animation-delay: 5s;
}

.orb3 {
    width: 300px;
    height: 300px;
    background: linear-gradient(135deg, #ff77a8, #ff6b9d);
    top: 50%;
    left: 50%;
    animation-delay: 10s;
}

@keyframes float {
    0%, 100% { transform: translate(0, 0) scale(1); }
    25% { transform: translate(100px, 50px) scale(1.1); }
    50% { transform: translate(-50px, 100px) scale(0.9); }
    75% { transform: translate(50px, -50px) scale(1.05); }
}

/* Main Container */
.auth-container {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
    position: relative;
    z-index: 1;
}

/* Modern Auth Card */
.auth-card {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(40px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 40px;
    padding: 60px;
    max-width: 520px;
    width: 100%;
    animation: slideUp 1s ease-out;
    box-shadow: 
        0 30px 60px rgba(0, 0, 0, 0.4),
        inset 0 1px 0 rgba(255, 255, 255, 0.1);
    position: relative;
    overflow: hidden;
}

.auth-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
    animation: shimmer 3s ease-in-out infinite;
}

@keyframes shimmer {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
}

@keyframes slideUp {
    from {
        opacity: 0;
        transform: translateY(60px) scale(0.9);
    }
    to {
        opacity: 1;
        transform: translateY(0) scale(1);
    }
}

/* Modern Header */
.auth-header {
    text-align: center;
    margin-bottom: 50px;
}

.auth-icon {
    width: 80px;
    height: 80px;
    background: linear-gradient(135deg, #4CAF50, #81C784);
    border-radius: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 25px;
    font-size: 2.5rem;
    color: #0a0a0f;
    animation: iconFloat 4s ease-in-out infinite;
    box-shadow: 
        0 20px 40px rgba(76, 175, 80, 0.3),
        0 0 0 1px rgba(76, 175, 80, 0.1);
}

@keyframes iconFloat {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-10px) scale(1.05); }
}

.auth-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 2.8rem;
    font-weight: 700;
    background: linear-gradient(135deg, #ffffff, #4CAF50, #81C784);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 12px;
    letter-spacing: -0.02em;
}

.auth-subtitle {
    color: rgba(255, 255, 255, 0.6);
    font-size: 1.1rem;
    font-weight: 400;
    letter-spacing: 0.02em;
}

/* Modern Form Styles */
.auth-form {
    margin-bottom: 40px;
}

.form-group {
    margin-bottom: 24px;
    position: relative;
}

.form-label {
    display: block;
    color: rgba(255, 255, 255, 0.8);
    font-weight: 500;
    margin-bottom: 8px;
    font-size: 0.9rem;
    letter-spacing: 0.02em;
}

.input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
}

.form-input {
    width: 100%;
    padding: 16px 20px 16px 50px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    color: #ffffff;
    font-size: 1rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    font-family: 'Inter', sans-serif;
    font-weight: 400;
}

.form-input::placeholder {
    color: rgba(255, 255, 255, 0.3);
}

.form-input:focus {
    outline: none;
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(76, 175, 80, 0.5);
    box-shadow: 
        0 0 0 4px rgba(76, 175, 80, 0.1),
        0 10px 30px rgba(76, 175, 80, 0.2);
    transform: translateY(-2px);
}

.input-icon {
    position: absolute;
    left: 20px;
    color: rgba(255, 255, 255, 0.4);
    font-size: 1.1rem;
    transition: all 0.3s ease;
    pointer-events: none;
}

.form-input:focus + .input-icon {
    color: #4CAF50;
    transform: scale(1.1);
}

/* Modern Submit Button */
.auth-submit-btn {
    width: 100%;
    padding: 18px;
    background: linear-gradient(135deg, #4CAF50, #81C784);
    color: #0a0a0f;
    border: none;
    border-radius: 16px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
    margin-top: 32px;
    font-family: 'Inter', sans-serif;
    letter-spacing: 0.02em;
    box-shadow: 
        0 10px 25px rgba(76, 175, 80, 0.3),
        0 0 0 1px rgba(76, 175, 80, 0.1);
}

.auth-submit-btn::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
    transition: left 0.6s ease;
}

.auth-submit-btn:hover::before {
    left: 100%;
}

.auth-submit-btn:hover {
    transform: translateY(-3px);
    box-shadow: 
        0 20px 40px rgba(76, 175, 80, 0.4),
        0 0 0 1px rgba(76, 175, 80, 0.2);
    background: linear-gradient(135deg, #45a049, #66bb6a);
}

.auth-submit-btn:active {
    transform: translateY(-1px);
}

/* Modern Alert Messages */
.alert-message {
    padding: 16px 20px;
    border-radius: 12px;
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 12px;
    animation: alertSlide 0.5s ease-out;
    backdrop-filter: blur(10px);
    border: 1px solid;
    font-size: 0.95rem;
}

@keyframes alertSlide {
    from {
        opacity: 0;
        transform: translateY(-20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.alert-success {
    background: rgba(76, 175, 80, 0.1);
    border-color: rgba(76, 175, 80, 0.3);
    color: #4CAF50;
}

.alert-error {
    background: rgba(244, 67, 54, 0.1);
    border-color: rgba(244, 67, 54, 0.3);
    color: #f44336;
}

.alert-icon {
    font-size: 1.2rem;
    flex-shrink: 0;
}

.alert-content h4 {
    margin: 0 0 4px 0;
    font-weight: 600;
    font-size: 1rem;
}

.alert-content p {
    margin: 0;
    font-size: 0.9rem;
    opacity: 0.9;
}

/* Modern Divider */
.auth-divider {
    text-align: center;
    margin: 40px 0;
    position: relative;
}

.auth-divider::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
}

.auth-divider span {
    background: rgba(10, 10, 15, 0.8);
    padding: 0 20px;
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.9rem;
    position: relative;
    z-index: 1;
    font-weight: 400;
}

/* Modern Switch Auth */
.switch-auth {
    text-align: center;
    margin-top: 32px;
}

.switch-auth p {
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 16px;
    font-size: 0.95rem;
}

.switch-auth a {
    color: #4CAF50;
    text-decoration: none;
    font-weight: 500;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: 12px;
    background: rgba(76, 175, 80, 0.1);
    border: 1px solid rgba(76, 175, 80, 0.2);
    font-size: 0.95rem;
}

.switch-auth a:hover {
    color: #81C784;
    background: rgba(76, 175, 80, 0.2);
    border-color: rgba(76, 175, 80, 0.3);
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(76, 175, 80, 0.2);
}

/* Phone Input Styles */
.phone-input-wrapper {
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.phone-input-wrapper:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(76, 175, 80, 0.3);
    transform: translateY(-1px);
}

.phone-input-wrapper:focus-within {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(76, 175, 80, 0.5);
    box-shadow: 
        0 0 0 4px rgba(76, 175, 80, 0.1),
        0 10px 30px rgba(76, 175, 80, 0.2);
    transform: translateY(-2px);
}

.phone-input-group {
    position: relative;
    display: flex;
    align-items: center;
    flex: 1;
}

.phone-input {
    width: 100%;
    padding: 16px 20px 16px 20px;
    background: transparent;
    border: none;
    color: #ffffff;
    font-size: 1rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    font-family: 'Inter', sans-serif;
    font-weight: 400;
}

.phone-input::placeholder {
    color: rgba(255, 255, 255, 0.3);
}

.phone-input:focus {
    outline: none;
    background: transparent;
}

.phone-icon {
    position: absolute;
    right: 20px;
    color: rgba(255, 255, 255, 0.4);
    font-size: 1.1rem;
    transition: all 0.3s ease;
    pointer-events: none;
}

.phone-input-wrapper:focus-within .phone-icon {
    color: #4CAF50;
    transform: scale(1.1);
}

/* Success/Error States for Phone Input */
.phone-input-wrapper.success {
    border-color: rgba(76, 175, 80, 0.5);
    background: rgba(76, 175, 80, 0.05);
}

.phone-input-wrapper.success .phone-icon {
    color: #4CAF50;
}

.phone-input-wrapper.error {
    border-color: rgba(244, 67, 54, 0.5);
    background: rgba(244, 67, 54, 0.05);
}

.phone-input-wrapper.error .phone-icon {
    color: #f44336;
}

/* Responsive Design */
@media (max-width: 768px) {
    .phone-input-wrapper {
        flex-direction: column;
        gap: 8px;
        align-items: stretch;
    }
    
    .country-select {
        min-width: auto;
        text-align: center;
    }
    
    .phone-input {
        padding: 16px 50px 16px 20px;
    }
}

/* Loading States */
.form-input.loading {
    background: rgba(255, 255, 255, 0.08);
    cursor: not-allowed;
}

.auth-submit-btn.loading {
    background: linear-gradient(135deg, #45a049, #66bb6a);
    cursor: not-allowed;
    opacity: 0.8;
}

/* Success/Error States */
.form-input.success {
    border-color: rgba(76, 175, 80, 0.5);
    background: rgba(76, 175, 80, 0.05);
}

.form-input.success + .input-icon {
    color: #4CAF50;
}

.form-input.error {
    border-color: rgba(244, 67, 54, 0.5);
    background: rgba(244, 67, 54, 0.05);
}

.form-input.error + .input-icon {
    color: #f44336;
}
</style>
{% endblock %}

{% block content %}
<div class="modern-bg"></div>
<div class="floating-orbs">
    <div class="orb orb1"></div>
    <div class="orb orb2"></div>
    <div class="orb orb3"></div>
</div>

<div class="auth-container">
    <div class="auth-card">
        <!-- Header -->
        <div class="auth-header">
            <div class="auth-icon">
                <i class="bi bi-person-plus-fill"></i>
            </div>
            <h1 class="auth-title">Crear Cuenta</h1>
            <p class="auth-subtitle">Únete a Tienda Prado</p>
        </div>

        <!-- Alert Messages -->
        {% if error %}
            <div class="alert-message alert-error">
                <div class="alert-icon">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                </div>
                <div class="alert-content">
                    <h4>Error de registro</h4>
                    <p>{{ message or 'Error al crear la cuenta. Por favor, inténtalo de nuevo.' }}</p>
                </div>
            </div>
        {% endif %}

        {% if success %}
            <div class="alert-message alert-success">
                <div class="alert-icon">
                    <i class="bi bi-check-circle-fill"></i>
                </div>
                <div class="alert-content">
                    <h4>¡Cuenta creada!</h4>
                    <p>{{ message or 'Tu cuenta ha sido creada exitosamente.' }}</p>
                </div>
            </div>
        {% endif %}

        <!-- Registration Form -->
        <form action="/register" method="POST" class="auth-form">
            <div class="form-group">
                <label for="nombre" class="form-label">Nombre Completo</label>
                <div class="input-wrapper">
                    <input type="text" 
                           id="nombre" 
                           name="nombre" 
                           class="form-input" 
                           placeholder="Juan Pérez" 
                           value="{{ nombre or '' }}"
                           required>
                    <span class="input-icon">
                        <i class="bi bi-person"></i>
                    </span>
                </div>
            </div>
            
            <div class="form-group">
                <label for="email" class="form-label">Email</label>
                <div class="input-wrapper">
                    <input type="email" 
                           id="email" 
                           name="email" 
                           class="form-input" 
                           placeholder="tu@email.com" 
                           value="{{ email or '' }}"
                           required>
                    <span class="input-icon">
                        <i class="bi bi-envelope"></i>
                    </span>
                </div>
            </div>

            <div class="form-group">
                <label for="telefono" class="form-label">Teléfono</label>
                <div class="phone-input-wrapper">
                    <select id="countryCode" name="countryCode" class="country-select">
                        <option value="+34">+34</option>
                        <option value="+33">+33</option>
                        <option value="+212">+212</option>
                        <option value="+44">+44</option>
                        <option value="+49">+49</option>
                        <option value="+39">+39</option>
                        <option value="+31">+31</option>
                        <option value="+41">+41</option>
                        <option value="+351">+351</option>
                        <option value="+46">+46</option>
                        <option value="+47">+47</option>
                        <option value="+45">+45</option>
                        <option value="+358">+358</option>
                        <option value="+48">+48</option>
                        <option value="+43">+43</option>
                        <option value="+32">+32</option>
                        <option value="+352">+352</option>
                        <option value="+353">+353</option>
                        <option value="+1">+1</option>
                        <option value="+61">+61</option>
                        <option value="+81">+81</option>
                        <option value="+82">+82</option>
                        <option value="+86">+86</option>
                        <option value="+91">+91</option>
                        <option value="+20">+20</option>
                        <option value="+966">+966</option>
                        <option value="+971">+971</option>
                        <option value="+972">+972</option>
                        <option value="+90">+90</option>
                        <option value="+7">+7</option>
                        <option value="+375">+375</option>
                        <option value="+380">+380</option>
                        <option value="+40">+40</option>
                        <option value="+421">+421</option>
                        <option value="+420">+420</option>
                        <option value="+36">+36</option>
                        <option value="+381">+381</option>
                        <option value="+385">+385</option>
                        <option value="+386">+386</option>
                        <option value="+389">+389</option>
                        <option value="+359">+359</option>
                        <option value="+30">+30</option>
                    </select>
                    <div class="phone-input-group">
                        <input type="tel" 
                               id="telefono" 
                               name="telefono" 
                               class="form-input phone-input" 
                               placeholder="912345678 (9 dígitos)"
                               value="{{ telefono or '' }}">
                        <span class="input-icon phone-icon">
                            <i class="bi bi-telephone"></i>
                        </span>
                    </div>
                </div>
            </div>
            
            <div class="form-group">
                <label for="contraseña" class="form-label">Contraseña</label>
                <div class="input-wrapper">
                    <input type="password" 
                           id="contraseña" 
                           name="contraseña" 
                           class="form-input" 
                           placeholder="Mínimo 3 caracteres" 
                           required>
                    <span class="input-icon">
                        <i class="bi bi-lock"></i>
                    </span>
                </div>
            </div>

            <button type="submit" class="auth-submit-btn">
                <i class="bi bi-person-plus me-2"></i>
                Crear Cuenta
            </button>
        </form>

        <!-- Divider -->
        <div class="auth-divider">
            <span>o</span>
        </div>

        <!-- Switch to Login -->
        <div class="switch-auth">
            <p>¿Ya tienes una cuenta?</p>
            <a href="/login">
                <i class="bi bi-box-arrow-in-right me-2"></i>
                Iniciar Sesión
            </a>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const form = document.querySelector('.auth-form');
    const inputs = document.querySelectorAll('.form-input, .phone-input');
    const submitBtn = document.querySelector('.auth-submit-btn');
    
    // Enhanced input interactions
    inputs.forEach(input => {
        input.addEventListener('focus', function() {
            this.parentElement.style.transform = 'translateY(-2px)';
        });
        
        input.addEventListener('blur', function() {
            this.parentElement.style.transform = 'translateY(0)';
            validateField(this);
        });
        
        input.addEventListener('input', function() {
            validateField(this);
        });
    });
    
    // Field validation
    function validateField(field) {
        const value = field.value.trim();
        const fieldName = field.name;
        
        // Remove previous states
        field.classList.remove('success', 'error');
        
        // Handle phone input wrapper for phone validation
        const phoneWrapper = field.closest('.phone-input-wrapper');
        if (phoneWrapper) {
            phoneWrapper.classList.remove('success', 'error');
        }
        
        if (value === '') return;
        
        let isValid = true;
        
        switch(fieldName) {
            case 'nombre':
                isValid = value.length >= 3;
                break;
            case 'email':
                isValid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value);
                break;
            case 'telefono':
                // Phone validation - exactly 9 digits
                isValid = /^\d{9}$/.test(value);
                console.log('Phone validation:', value, isValid); // Debug log
                break;
            case 'contraseña':
                isValid = value.length >= 3;
                break;
        }
        
        if (phoneWrapper) {
            phoneWrapper.classList.add(isValid ? 'success' : 'error');
        } else {
            field.classList.add(isValid ? 'success' : 'error');
        }
    }
    
    // Form submission
    form.addEventListener('submit', function(e) {
        e.preventDefault();
        
        // Get phone number with country code
        const countryCode = document.getElementById('countryCode').value;
        const phoneNumber = document.getElementById('telefono').value.trim();
        
        // Validate the original phone number (without country code) first
        const phoneInput = document.getElementById('telefono');
        const originalPhoneValue = phoneNumber;
        
        // Check if phone number is valid (9 digits)
        if (!/^\d{9}$/.test(originalPhoneValue)) {
            phoneInput.classList.add('error');
            phoneInput.closest('.phone-input-wrapper').classList.add('error');
            return;
        }
        
        const fullPhoneNumber = countryCode + ' ' + phoneNumber;
        
        // Update the phone input value before submission
        document.getElementById('telefono').value = fullPhoneNumber;
        
        // Validate all other fields (skip phone since we already validated it)
        let isFormValid = true;
        inputs.forEach(input => {
            if (input.id === 'telefono') return; // Skip phone validation
            
            validateField(input);
            const phoneWrapper = input.closest('.phone-input-wrapper');
            if (phoneWrapper && phoneWrapper.classList.contains('error')) {
                isFormValid = false;
            } else if (input.classList.contains('error')) {
                isFormValid = false;
            }
        });
        
        if (isFormValid) {
            // Show loading state
            submitBtn.classList.add('loading');
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="bi bi-hourglass-split me-2"></i>Creando cuenta...';
            
            // Submit form
            form.submit();
        } else {
            // Shake animation for invalid form
            form.style.animation = 'shake 0.5s';
            setTimeout(() => {
                form.style.animation = '';
            }, 500);
        }
    });
    
    // Add shake animation
    const style = document.createElement('style');
    style.textContent = `
        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-10px); }
            75% { transform: translateX(10px); }
        }
    `;
    document.head.appendChild(style);
});
</script>
